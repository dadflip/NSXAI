<?xml version="1.0"?>
<Ontology xmlns="http://www.w3.org/2002/07/owl#"
    xml:base="http://meututor.com.br/Ontologies/meututor_domain_cp.owl"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    ontologyIRI="http://meututor.com.br/Ontologies/meututor_domain_cp.owl">

    <Prefix name="mtcp"
        IRI="http://meututor.com.br/Ontologies/meututor_domain_cp.owl#"/>

    <!-- Classes -->
    <Declaration><Class IRI="#Context"/></Declaration>
    <Declaration><Class IRI="#Curriculum"/></Declaration>
    <Declaration><Class IRI="#Depth"/></Declaration>

    <!-- Object Properties -->
    <Declaration><ObjectProperty IRI="#hasContext"/></Declaration>
    <Declaration><ObjectProperty IRI="#isChildOfCurriculum"/></Declaration>
    <Declaration><ObjectProperty IRI="#isComposedByContext"/></Declaration>
    <Declaration><ObjectProperty IRI="#isComposedByDepth"/></Declaration>
    <Declaration><ObjectProperty IRI="#isComposedByLaterality"/></Declaration>
    <Declaration><ObjectProperty IRI="#isParentOfCurriculum"/></Declaration>

    <!-- Data Properties -->
    <Declaration><DataProperty IRI="#description"/></Declaration>
    <Declaration><DataProperty IRI="#importanceLevel"/></Declaration>
    <Declaration><DataProperty IRI="#issue"/></Declaration>
    <Declaration><DataProperty IRI="#type"/></Declaration>

</Ontology>