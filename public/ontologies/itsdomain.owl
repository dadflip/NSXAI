    <!-- http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context -->

    <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#issue"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">It is composed by different context or standpoints about a knowledge domain. This concerns to the several interpretation which can be given to a certain domain, composing in different representations (approachs) of a same knowledge object.</rdfs:comment>
        <rdfs:comment xml:lang="pt">É composto por diferentes contextos ou pontos de vista sobre um domínio de conhecimento. Isso diz respeito às várias interpretações que podem ser dadas a um tal domínio, constituindo-se em representações (abordagens) diferentes de um mesmo objeto de conhecimento.</rdfs:comment>
    </owl:Class>
    


    <!-- http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum -->

    <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByContext"/>
                <owl:someValuesFrom rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByDepth"/>
                <owl:someValuesFrom rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByLaterality"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByContext"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByDepth"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#issue"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"></rdfs:comment>
        <rdfs:comment xml:lang="pt">Formado por um par &lt;Contexto, Profundidade&gt;. Além disso, constituído por um conjunto de unidades pedagógicas, definidas em função de objetivos de ensino/aprendizagem.</rdfs:comment>
    </owl:Class>
    


    <!-- http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth -->

    <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#issue"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">It is relative to a particular context. It is concerning to some way of refining in the perception language, that is, the stratification of the several epistemological levels of knowledge object perception in appreciation.</rdfs:comment>
        <rdfs:comment xml:lang="pt">é relativa a um contexto particular. Ela é concernente a alguma forma de refinamento na linguagem de percepção, ou seja, a estratificação dos vários níveis epistemológicos de percepção do objeto de conhecimento em apreciação.</rdfs:comment>
    </owl:Class>
    


    <!-- http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge -->

    <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge">
        <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    </owl:Class>
    


    <!-- http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug -->

    <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug">
        <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#isComposedByProblem"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#rate"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug_Misconception -->

    <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug_Misconception">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue"/>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
                            <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception"/>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBug"/>
                <owl:someValuesFrom rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasMisconception"/>
                <owl:someValuesFrom rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBug"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasMisconception"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


