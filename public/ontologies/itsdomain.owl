                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#rate"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit -->

    <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit">
