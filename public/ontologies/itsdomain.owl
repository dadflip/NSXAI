    <!-- http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Bug -->

    <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Bug">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue"/>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
                            <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error"/>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBug"/>
                <owl:someValuesFrom rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
