<?xml version="1.0"?>
<rdf:RDF
    xmlns:xsp="http://www.owl-ontologies.com/2005/08/07/xsp.owl#"
    xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
    xmlns:Curriculum="http://surveys.ness.com.br/ontologies/its/its.domain.curriculum.owl#"
    xmlns:protege="http://protege.stanford.edu/plugins/owl/protege#"
    xmlns:swrl="http://www.w3.org/2003/11/swrl#"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:Resource="http://surveys.nees.com.br/ontologies/its/its.domain.resource.owl#"
    xmlns:Pedagogical="http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#"
  xml:base="http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl">
  <owl:Ontology rdf:about="">
    <owl:imports rdf:resource="http://surveys.nees.com.br/ontologies/its/its.domain.owl"/>
  </owl:Ontology>
  <rdfs:Class rdf:about="http://surveys.nees.com.br/ontologies/its/its.domain.cp.owl#Curriculum"/>
  <owl:Class rdf:ID="ProblemNext">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="THINGInstrutionalPlan"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="CurriculumUnit">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#THINGInstrutionalPlan"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:maxCardinality>
        <owl:onProperty>
          <owl:ObjectProperty rdf:ID="next_Curriculum"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="ResourceUnit">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="Sequencing"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="ProblemUnit">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#Sequencing"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="PedagogicalModel">
    <rdfs:comment xml:lang="en">Answer the question: How to teach? in a educational system.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Responde a questão: Como ensinar? em um sistema educacional.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="#Sequencing">
    <rdfs:comment xml:lang="pt">garantir que a unidade não aponta para ela mesmo!!!!!!!!!!!!!!!!!!!!!!!!!!!!</rdfs:comment>
    <rdfs:comment xml:lang="en">A Sequencing is a map that represents the intended use of the content through structured units of instruction (curriculum).</rdfs:comment>
    <rdfs:comment xml:lang="pt">O seqüenciamento é um mapa que representa a estrutura em que o conteúdo será utilizado.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Não pode ser instanciada!!!!</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Deve existir pelo menos um item que aponte para o null.</rdfs:comment>
    <rdfs:subClassOf>
      <owl:Class rdf:about="#THINGInstrutionalPlan"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="THINGPedagogicalModel"/>
  <owl:Class rdf:about="#THINGInstrutionalPlan">
    <rdfs:subClassOf rdf:resource="#THINGPedagogicalModel"/>
  </owl:Class>
  <owl:Class rdf:ID="InstrutionalPlan">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >cada unidade pedagogica tem q pertencer ao curriculo!!!!!!!!!!!!!</rdfs:comment>
    <rdfs:comment xml:lang="en">Instructional Plan Strategy.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Estratégia do plano instrucional</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#PedagogicalModel"/>
  </owl:Class>
  <owl:Class rdf:ID="Tactic">
    <rdfs:subClassOf rdf:resource="#PedagogicalModel"/>
    <rdfs:comment xml:lang="pt">Representa todas as ações que o sistema educacional pode tomar objetivando o ensino.</rdfs:comment>
    <rdfs:comment xml:lang="en">Represents all the actions the educational system can do in order to teach.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:ID="Strategy">
    <rdfs:comment xml:lang="pt">Representa o mecanismo de ensino no planejamento instrucional.</rdfs:comment>
    <rdfs:comment xml:lang="en">Represents the teaching  mechanism in the instrutional plan.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="#PedagogicalModel"/>
  </owl:Class>
  <owl:ObjectProperty rdf:ID="has_Sequencing">
    <rdfs:comment xml:lang="pt">Mostra que seqüenciamento está ligado à esse plano instrucional.</rdfs:comment>
    <rdfs:domain rdf:resource="#InstrutionalPlan"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="#Sequencing"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="isParentOf_Tactic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:range rdf:resource="#Tactic"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="isChildOf_Tactic"/>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="#Tactic"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="has_Curriculum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:comment xml:lang="pt">Liga o plano institucional à um currículo.</rdfs:comment>
    <rdfs:range rdf:resource="http://surveys.nees.com.br/ontologies/its/its.domain.cp.owl#Curriculum"/>
    <rdfs:domain rdf:resource="#CurriculumUnit"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="has_Resource">
    <rdfs:comment xml:lang="pt">Aponta para o recurso que está sendo usado. Não pode ser do tipo problema.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://surveys.nees.com.br/ontologies/its/its.domain.resource.owl#Resource"/>
    <rdfs:domain rdf:resource="#ResourceUnit"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="isParentOf_Strategy">
    <rdfs:domain rdf:resource="#Strategy"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:ID="isChildOf_Strategy"/>
    </owl:inverseOf>
    <rdfs:range rdf:resource="#Strategy"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="has_PedagogicalUnit">
    <rdfs:range rdf:resource="http://surveys.nees.com.br/ontologies/its/its.domain.curriculum.owlPedagogicalUnit"/>
    <rdfs:domain rdf:resource="#InstrutionalPlan"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="has_domain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="has_ProblemNext">
    <rdfs:range rdf:resource="#ProblemNext"/>
    <rdfs:domain rdf:resource="#ProblemUnit"/>
    <rdfs:comment xml:lang="pt">Vai apontar para a classe ProblemNext, nela é que vai conter a unidade que esse problema aponta. Essa propriedade possiu restrição de cardinalidade pois como cada problema se divide em 5 nível de "acerto", pode haver até 5 caminhos para seguir após o problema.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="next_Unit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Aponta pra a próxima unidade. Pode ser problema ou outro recurso.</rdfs:comment>
    <rdfs:range rdf:resource="#ResourceUnit"/>
    <rdfs:domain rdf:resource="#ResourceUnit"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#isChildOf_Strategy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:domain rdf:resource="#Strategy"/>
    <owl:inverseOf rdf:resource="#isParentOf_Strategy"/>
    <rdfs:range rdf:resource="#Strategy"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="previous_Unit">
    <rdfs:range rdf:resource="#ResourceUnit"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Aponta para unidade anterior.</rdfs:comment>
    <rdfs:domain rdf:resource="#ResourceUnit"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#next_Curriculum">
    <rdfs:range rdf:resource="#CurriculumUnit"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="#CurriculumUnit"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="strategicTutoring">
    <rdfs:range rdf:resource="#Strategy"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:comment xml:lang="pt">A estratégia é como um modelo com configurações para selecionar táticas.</rdfs:comment>
    <rdfs:comment xml:lang="en">The strategy is alike a template with configuration to select tactics.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="has_Problem">
    <rdfs:domain rdf:resource="#ProblemUnit"/>
    <rdfs:range rdf:resource="http://surveys.nees.com.br/ontologies/its/its.domain.resource.owl#Problem"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:comment xml:lang="pt">Aponta para um recurso do tipo problema.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="#isChildOf_Tactic">
    <rdfs:range rdf:resource="#Tactic"/>
    <rdfs:domain rdf:resource="#Tactic"/>
    <owl:inverseOf rdf:resource="#isParentOf_Tactic"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:ID="statement">
    <rdfs:domain rdf:resource="#ResourceUnit"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="strategy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="#Strategy"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="isExplained">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="#ProblemUnit"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="score_Max">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="#ProblemNext"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Porcentagem máxima de acerto no problema.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="tactic">
    <rdfs:domain rdf:resource="#Tactic"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="Level">
    <rdfs:domain rdf:resource="#InstrutionalPlan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="pt">Vai definir o nível. Pode ser: básico, intermediário, avançado.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="score_Min">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment xml:lang="pt">Porcentagem mínima de acerto no problema.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="#ProblemNext"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="typeTactic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="#Tactic"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="typeStrategy">
    <rdfs:domain rdf:resource="#Strategy"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="type">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="#ResourceUnit"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="time">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >Represent the time (time represented in minutes) spended or necessary in each problem solving process.</rdfs:comment>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="typeStrategyTutoring">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="typeAssessment">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:FunctionalProperty rdf:ID="abilityScoreStandardDeviation">
    <rdfs:domain rdf:resource="http://surveys.nees.com.br/ontologies/its/its.domain.owl#Domain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:ID="value">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:ID="abilityScoreMean">
    <rdfs:domain rdf:resource="http://surveys.nees.com.br/ontologies/its/its.domain.owl#Domain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </owl:FunctionalProperty>
</rdf:RDF>

