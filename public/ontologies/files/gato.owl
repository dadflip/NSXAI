    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <Literal xml:lang="en">
            GATO integrates GADO Full (gamification) with the ITS Pedagogical ontology
            to model a complete Gamified Intelligent Tutoring System.
            Defines GamifiedITS and StudentModel, and reuses GamificationModel from GADO Full.
        </Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <Literal xml:lang="en">GATO - Gamified ITS Ontology</Literal>
    </Annotation>
