<?xml version="1.0"?>
<rdf:RDF
    xmlns="http://surveys.nees.com.br/ontologies/its_domain.owl#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:xml="http://www.w3.org/XML/1998/namespace"
    xmlns:its="http://surveys.nees.com.br/ontologies/its_domain.owl#"
    xmlns:mt="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#"
    xmlns:mtcp="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#"
    xmlns:mtcu="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#"
    xmlns:mtr="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#"
    xml:base="http://surveys.nees.com.br/ontologies/its_domain.owl">

  <owl:Ontology rdf:about="http://surveys.nees.com.br/ontologies/its_domain.owl">
    <rdfs:label xml:lang="en">ITS Domain Ontology</rdfs:label>
    <rdfs:comment xml:lang="en">
      Consolidated ITS domain ontology covering courses, knowledge domains, curriculum,
      pedagogical units, and learning resources. Derived from MeuTutor domain ontologies.
      The pedagogical layer (strategies, tactics, instructional plans) is defined separately
      in its.pedagogical.owl, which imports this ontology.
    </rdfs:comment>
    <owl:versionInfo>1.1</owl:versionInfo>
  </owl:Ontology>


  <!-- ============================================================
       DATATYPES
       ============================================================ -->

  <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
  <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#time"/>


  <!-- ============================================================
       ANNOTATION PROPERTIES
       ============================================================ -->

  <!-- mt:hasDomain – used as an annotation on external resources -->
  <owl:AnnotationProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#hasDomain"/>


  <!-- ============================================================
       OBJECT PROPERTIES – Domain / Sub-domain
       ============================================================ -->

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#hasSubDomain">
    <owl:inverseOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#isSubDomainOf"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:comment xml:lang="en">Links a domain to one of its sub-domains.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#isSubDomainOf">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#hasDomains">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Competence"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:comment xml:lang="en">Links a Competence to the Domains it covers.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#associatedDomain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:comment xml:lang="en">Associates any resource with its knowledge domain.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#has_Domain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#hasEloRating">
    <rdfs:comment xml:lang="en">Elo rating associated with a domain entity (used for student modelling).</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#hasLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:comment xml:lang="en">Proficiency level associated with a domain entity.</rdfs:comment>
  </owl:ObjectProperty>

  <!-- Domain composition -->
  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#isComposedByContext">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context"/>
    <rdfs:comment xml:lang="en">Relates a Domain to the Contexts from which it can be viewed.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#isComposedByDepth">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth"/>
    <rdfs:comment xml:lang="en">Relates a Domain to the Depth levels used to stratify its knowledge.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#isComposedByCurriculum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:comment xml:lang="en">Relates a Domain to its constituent Curriculum units.</rdfs:comment>
  </owl:ObjectProperty>


  <!-- ============================================================
       OBJECT PROPERTIES – Context / Depth / Curriculum (mtcp)
       ============================================================ -->

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#hasContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context"/>
    <rdfs:comment xml:lang="en">Associates an entity with its Context.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context"/>
    <rdfs:comment xml:lang="en">A Curriculum is composed by exactly one Context.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByDepth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth"/>
    <rdfs:comment xml:lang="en">A Curriculum is composed by exactly one Depth level.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByLaterality">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:comment xml:lang="en">
      Relates a Curriculum to sibling Curricula that represent prerequisite knowledge
      from a particular Context/Depth perspective.
    </rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isParentOfCurriculum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <owl:inverseOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isChildOfCurriculum"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:comment xml:lang="en">Transitive parent relationship between Curriculum nodes.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isChildOfCurriculum">
    <owl:inverseOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isParentOfCurriculum"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:comment xml:lang="en">Transitive child relationship between Curriculum nodes.</rdfs:comment>
  </owl:ObjectProperty>


  <!-- ============================================================
       OBJECT PROPERTIES – Curriculum / Knowledge (mtcu)
       ============================================================ -->

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasPedagogicalUnit">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit"/>
    <rdfs:comment xml:lang="en">A Curriculum contains one or more Pedagogical Units.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasKnowledgeUnit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit"/>
    <rdfs:comment xml:lang="en">A Pedagogical Unit is associated with exactly one Knowledge Unit.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#UniversalGenericOperator"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge"/>
    <rdfs:comment xml:lang="en">Associates a knowledge entity with its Behavioural Knowledge definition.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
    <rdfs:comment xml:lang="en">Associates a knowledge entity with its Conceptual Knowledge definition.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasCatalogue">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#GenericOperator"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue"/>
    <rdfs:comment xml:lang="en">Associates a knowledge entity with its bug/error/misconception Catalogue.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBug">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug_Misconception"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Bug"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasError">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Bug"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Misconception"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasMisconception">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug_Misconception"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Misconception"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#isComposedByProblem">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:comment xml:lang="en">Relates a catalogue entry to the problem that triggers it.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#isComposedByLaterality">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:comment xml:lang="en">
      Relates a Knowledge Unit to prerequisite Curricula (lateral knowledge),
      i.e. supportive knowledge from a given Context/Depth perspective.
    </rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasCurriculum">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ResourceWeight"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#has_Curriculum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:comment xml:lang="en">Functional shortcut linking any entity to its single Curriculum.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasCurriculumInformation">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#CKCurriculumInformation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasDomain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:comment xml:lang="en">Links a ConceptualKnowledge node to its knowledge Domain.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasDiscrepancy">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#GenericOperator"/>
    <rdfs:comment xml:lang="en">Records a discrepancy detected by a Generic Operator.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasSuperConceptualKnowledge">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
    <rdfs:comment xml:lang="en">Points to the parent ConceptualKnowledge in a generalisation hierarchy.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasTags">
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
    <rdfs:comment xml:lang="en">Free-text tags associated with a ConceptualKnowledge node.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConsistency">
    <rdfs:comment xml:lang="en">Consistency indicator for a curriculum entity.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasResource">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ResourceWeight"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#has_MissConception">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Diagnosis"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
    <rdfs:comment xml:lang="en">Links a Diagnosis to the ConceptualKnowledge node that represents the misconception.</rdfs:comment>
  </owl:ObjectProperty>

  <!-- Learning Object sub-properties -->
  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasLO">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:comment xml:lang="en">Super-property grouping all Learning Object associations.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConcept">
    <rdfs:subPropertyOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasLO"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Concept"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasContent">
    <rdfs:subPropertyOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasLO"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Content"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasExample">
    <rdfs:subPropertyOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasLO"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Exercise"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasExplanation">
    <rdfs:subPropertyOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasLO"/>
    <rdfs:comment xml:lang="en">Links a knowledge entity to an explanatory Learning Object.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#difficulty">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit"/>
    <rdfs:comment xml:lang="en">
      Represents how difficult the learning resource is for the typical target audience.
    </rdfs:comment>
  </owl:ObjectProperty>


  <!-- ============================================================
       OBJECT PROPERTIES – Resource (mtr)
       ============================================================ -->

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#hasResource">
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ResourceList">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#CompositeResource"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:comment xml:lang="en">Enumerates the atomic resources that compose a CompositeResource.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#hasEvaluation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#hasOption">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option"/>
    <rdfs:comment xml:lang="en">Generic option association; specialised by problem-type sub-properties.</rdfs:comment>
  </owl:ObjectProperty>

  <!-- Problem-type option properties -->
  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#multipleChoiceHasOption">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceProblem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceOption"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#multipleChoiceAnswer">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceProblem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceOption"/>
    <rdfs:comment xml:lang="en">Identifies the correct option(s) in a MultipleChoiceProblem.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#trueOrFalseHasOption">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#TrueOrFalseProblem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#TrueOrFalseOption"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#fillBlanksHasOption">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#FillBlanksProblem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#FillBlanksOption"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#LeftColumn">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnProblem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnOption"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#RightColumn">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnProblem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnOption"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnAnswer">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnProblem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnOption"/>
    <rdfs:comment xml:lang="en">Identifies the correct matching answer(s) in a MatchColumnProblem.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#matched_To">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnOption"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnOption"/>
    <rdfs:comment xml:lang="en">Links a left-column option to its corresponding right-column match.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_discursiveOption">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#DiscursiveProblem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#DiscursiveOption"/>
  </owl:ObjectProperty>

  <!-- Resolution chain -->
  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_Resolution">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resolution"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_ResolutionMethod">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resolution"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ResolutionMethod"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_MethodStep">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ResolutionMethod"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MethodStep"/>
  </owl:ObjectProperty>

  <!-- Hints -->
  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_hint">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#isParentOfHint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <owl:inverseOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#isChildOfHint"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#isChildOfHint">
    <owl:inverseOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#isParentOfHint"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint"/>
  </owl:ObjectProperty>

  <!-- Diagnosis -->
  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_Diagnosis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Diagnosis"/>
    <rdfs:comment xml:lang="en">Links an Option to the Diagnosis it triggers when chosen.</rdfs:comment>
  </owl:ObjectProperty>

  <!-- Evaluation context/depth -->
  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_Context">
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#WritingEvaluation"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_Depth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#WritingEvaluation"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_Domain">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_Problems">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem"/>
  </owl:ObjectProperty>

  <!-- Forms / Questions -->
  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_Questions">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Form"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Question"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#related_Curriculum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Question"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
  </owl:ObjectProperty>

  <!-- Comments -->
  <owl:ObjectProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_comments">
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Comment"/>
  </owl:ObjectProperty>

  <!-- ITS-specific -->
  <owl:ObjectProperty rdf:about="http://surveys.nees.com.br/ontologies/its_domain.owl#teachesDomain">
    <rdfs:domain rdf:resource="http://surveys.nees.com.br/ontologies/its_domain.owl#Course"/>
    <rdfs:range  rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:comment xml:lang="en">Specifies the knowledge Domain taught by a Course.</rdfs:comment>
  </owl:ObjectProperty>


  <!-- ============================================================
       DATATYPE PROPERTIES – mtcp
       ============================================================ -->

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#description">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#importanceLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Relative importance of this Curriculum node within the domain.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#issue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Human-readable label / identifier for a Context, Curriculum or Depth node.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#type">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Classification type of a Context (e.g. formal, informal, professional).</rdfs:comment>
  </owl:DatatypeProperty>


  <!-- ============================================================
       DATATYPE PROPERTIES – mtcu
       ============================================================ -->

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#description">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ckType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Classifies the type of conceptual knowledge (e.g. declarative, procedural).</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#issue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Human-readable label / identifier for a ConceptualKnowledge or PedagogicalUnit node.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#domain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">String identifier of the knowledge domain (used when a full IRI reference is not available).</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#precedence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#CKCurriculumInformation"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    <rdfs:comment xml:lang="en">Ordering precedence of a knowledge node within its curriculum.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#cluster">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#CKCurriculumInformation"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    <rdfs:comment xml:lang="en">Cluster identifier grouping related ConceptualKnowledge nodes.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#rate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment xml:lang="en">Frequency/probability rate of the bug, error, or misconception.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#weight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ResourceWeight"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment xml:lang="en">Relative weight of a resource within a pedagogical unit.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#totalWeight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>

  <!-- BKT parameters -->
  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasPL0">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment xml:lang="en">BKT parameter: initial probability of knowledge (P(L0)).</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasPT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
