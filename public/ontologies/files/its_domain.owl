  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#type_Test">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">
      Identifies whether an evaluation is simple (linked to a specific Domain or Curriculum)
      or comprehensive (covering all domains).
    </rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#size">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    <rdfs:comment xml:lang="en">Number of problems included in an evaluation.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#subjects">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">
      Identifies the subject(s) covered by a simple evaluation
      (e.g. a specific domain, a specific curriculum, or all domains).
    </rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#corrected">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
    <rdfs:comment xml:lang="en">Indicates whether the evaluation has been corrected / graded.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_Epoch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    <rdfs:comment xml:lang="en">Training epoch number associated with a problem-based evaluation (used in adaptive systems).</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#startDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Activity"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#WritingEvaluation"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#endDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Activity"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#WritingEvaluation"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#submmitedDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#weight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Activity"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>


  <!-- ============================================================
       DATATYPE PROPERTIES – mt (Domain)
       ============================================================ -->

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#domain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">String label for the Domain (used alongside the IRI).</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#type">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Classification type of the Domain (e.g. academic, professional, vocational).</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#desiredPoints">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    <rdfs:comment xml:lang="en">Target score or point threshold for a student performance goal.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#value">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
  </owl:DatatypeProperty>


  <!-- ============================================================
       DATATYPE PROPERTIES – ITS-specific
       ============================================================ -->

  <owl:DatatypeProperty rdf:about="http://surveys.nees.com.br/ontologies/its_domain.owl#courseName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://surveys.nees.com.br/ontologies/its_domain.owl#Course"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Official name of the Course.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://surveys.nees.com.br/ontologies/its_domain.owl#teacher">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://surveys.nees.com.br/ontologies/its_domain.owl#Course"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Name of the instructor responsible for the Course.</rdfs:comment>
  </owl:DatatypeProperty>


  <!-- ============================================================
       CLASSES – Context / Depth / Curriculum (mtcp)
       ============================================================ -->

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#issue"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">
      Represents a particular standpoint or interpretation of a knowledge domain.
      Different Contexts yield different representations of the same knowledge object.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#issue"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">
      Stratifies the epistemological levels of knowledge-object perception within a given Context.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByContext"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByDepth"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isComposedByLaterality"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#issue"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">
      A Curriculum node is a &lt;Context, Depth&gt; pair that groups a set of Pedagogical Units
      defined according to teaching/learning objectives.
    </rdfs:comment>
  </owl:Class>


  <!-- ============================================================
       CLASSES – Knowledge (mtcu)
       ============================================================ -->

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    <rdfs:comment xml:lang="en">
      Encodes the domain-specific inference rules or procedures a student should be able to perform.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    <rdfs:comment xml:lang="en">
      Contains the definitions of concepts underlying the Behavioural Knowledge,
      i.e. the concepts involved in an inference mechanism.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#CKCurriculumInformation">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    <rdfs:comment xml:lang="en">Metadata linking a ConceptualKnowledge node to its Curriculum position (cluster, precedence).</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#isComposedByLaterality"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge"/>
        <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge"/>
        <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">
      Groups support knowledge for problem-solving: concepts, results, examples, counter-examples,
      hints, and analogous problems (from the same class).
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#issue"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">
      A Pedagogical Unit (PU) corresponds to a set of problems and resources ordered
      according to pedagogical criteria.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ResourceWeight">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    <rdfs:comment xml:lang="en">Associates a resource with its relative weight within a pedagogical unit.</rdfs:comment>
  </owl:Class>


  <!-- ============================================================
       CLASSES – Catalogue (Bugs / Errors / Misconceptions)
       ============================================================ -->

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    <rdfs:comment xml:lang="en">Abstract catalogue of known student difficulties (bugs, errors, misconceptions).</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#isComposedByProblem"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge"/>
        <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#rate"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">A systematic procedural error in the student's behavioural knowledge.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#isComposedByProblem"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">A specific incorrect response or calculation error.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge"/>
        <owl:someValuesFrom rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#isComposedByProblem"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge"/>
        <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#rate"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">A faulty conceptual belief held by the student.</rdfs:comment>
  </owl:Class>

  <!-- Intersection classes -->
  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug_Misconception">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception"/>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBug"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasMisconception"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">A catalogue entry that is simultaneously a Bug and a Misconception.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Bug">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error"/>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBug"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasError"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">A catalogue entry that is simultaneously a Bug and an Error.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Misconception">
    <owl:equivalentClass>
      <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error"/>
          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception"/>
        </owl:intersectionOf>
      </owl:Class>
    </owl:equivalentClass>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasError"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasMisconception"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">A catalogue entry that is simultaneously an Error and a Misconception.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#GenericOperator">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasCatalogue"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasDiscrepancy"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">
      Defines how the system knowledge (Rs*k) and the bug/misconception catalogues
      interact to create a diagnosis space.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#UniversalGenericOperator">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum"/>
    <rdfs:comment xml:lang="en">
      Represents any Behavioural Knowledge associated with all bugs in the bug catalogue.
    </rdfs:comment>
  </owl:Class>


  <!-- ============================================================
       CLASSES – Resources (mtr)
       ============================================================ -->

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource"/>
  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Concept">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:comment xml:lang="en">A definitional concept resource presented to the student.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Content">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:comment xml:lang="en">A content resource (e.g. lecture notes, video, reading material).</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Exercise">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:comment xml:lang="en">A worked example or exercise resource.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Activity">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:comment xml:lang="en">A student activity resource with defined start/end dates and weight.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Question">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:comment xml:lang="en">A survey or form question linked to a Curriculum.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#CompositeResource">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ResourceList"/>
        <owl:someValuesFrom>
          <owl:Class>
            <owl:intersectionOf rdf:parseType="Collection">
              <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
              <owl:Class>
                <owl:complementOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#CompositeResource"/>
              </owl:Class>
            </owl:intersectionOf>
          </owl:Class>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">A resource composed of multiple atomic (non-composite) resources.</rdfs:comment>
  </owl:Class>

  <!-- Evaluation resources -->
  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:comment xml:lang="en">Abstract superclass for all evaluation types.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource"/>
    <rdfs:comment xml:lang="en">An evaluation composed of a set of Problems.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#WritingEvaluation">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource"/>
    <rdfs:comment xml:lang="en">A free-text writing evaluation.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Form">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource"/>
    <rdfs:comment xml:lang="en">A form-based evaluation containing survey Questions.</rdfs:comment>
  </owl:Class>

  <!-- Problems -->
  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:comment xml:lang="en">Abstract superclass for all problem types.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceProblem">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#multipleChoiceHasOption"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#multipleChoiceAnswer"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#TrueOrFalseProblem"/>
    <owl:disjointWith rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#FillBlanksProblem"/>
    <owl:disjointWith rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnProblem"/>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#TrueOrFalseProblem">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#trueOrFalseHasOption"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#FillBlanksProblem"/>
    <owl:disjointWith rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnProblem"/>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#FillBlanksProblem">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#fillBlanksHasOption"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnProblem"/>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnProblem">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#LeftColumn"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#RightColumn"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnAnswer"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#DiscursiveProblem">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#has_discursiveOption"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">A free-text / discursive problem requiring an open-ended written answer.</rdfs:comment>
  </owl:Class>

  <!-- Options -->
  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#item"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">Abstract superclass for all answer options.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceOption">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option"/>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#TrueOrFalseOption">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#OptionAnswer"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#FillBlanksOption">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option"/>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnOption">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option"/>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#DiscursiveOption">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option"/>
  </owl:Class>

  <!-- Resolution chain classes -->
  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resolution">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#resolution"/>
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">The worked solution associated with a Problem.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ResolutionMethod">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource"/>
    <rdfs:comment xml:lang="en">A named resolution strategy applicable to a problem class.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MethodStep">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource"/>
    <rdfs:comment xml:lang="en">An individual step within a ResolutionMethod.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource"/>
    <rdfs:comment xml:lang="en">A scaffolded hint provided to a student during problem-solving; hints form a tree.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Diagnosis">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource"/>
    <rdfs:comment xml:lang="en">A diagnostic result triggered by a student selecting a particular Option.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Comment">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource"/>
    <rdfs:comment xml:lang="en">A peer or instructor comment attached to a Problem.</rdfs:comment>
  </owl:Class>


  <!-- ============================================================
       CLASSES – Domain model (mt)
       ============================================================ -->

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#DomainModel">
    <rdfs:comment xml:lang="en">Answers the question "What to teach?" in an educational system.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#THINGDomain">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#DomainModel"/>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#DomainModel"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#isComposedByContext"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#isComposedByCurriculum"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#isComposedByDepth"/>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:comment xml:lang="en">
      A knowledge Domain is the subject-matter area taught by an ITS.
      It is structured by at least one Context, Depth level, and Curriculum.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Competence">
    <rdfs:subClassOf rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#THINGDomain"/>
    <rdfs:comment xml:lang="en">A competence groups several Domains that a student is expected to master.</rdfs:comment>
  </owl:Class>


  <!-- ============================================================
       CLASSES – ITS-specific
       ============================================================ -->

  <owl:Class rdf:about="http://surveys.nees.com.br/ontologies/its_domain.owl#Course">
    <rdfs:comment xml:lang="en">
      An ITS Course bundles a set of knowledge Domains and is delivered to enrolled students.
    </rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://rdfs.org/sioc/ns#UserAccount">
    <rdfs:comment xml:lang="en">A user account (student or instructor) in the ITS platform (from SIOC vocabulary).</rdfs:comment>
  </owl:Class>

</rdf:RDF>