          <rdf:Description rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment xml:lang="en">BKT parameter: probability of learning / transition (P(T)).</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasPG">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment xml:lang="en">BKT parameter: probability of a correct guess (P(G)).</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasPS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum"/>
    <rdfs:range  rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment xml:lang="en">BKT parameter: probability of a slip / incorrect answer despite knowledge (P(S)).</rdfs:comment>
  </owl:DatatypeProperty>


