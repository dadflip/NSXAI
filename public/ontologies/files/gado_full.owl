    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#loopQuality</IRI><Literal xml:lang="en">A property indicating the quality or design elegance of an activity loop.</Literal></AnnotationAssertion>
