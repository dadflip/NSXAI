    <!-- ═══════════════════════════════════════════════════
         ANNOTATIONS
         ═══════════════════════════════════════════════════ -->
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>gc:SDT_Autonomy</IRI><Literal xml:lang="en">Autonomy is the need to have independence and to be able make own choices.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>gc:SDT_Competence</IRI><Literal xml:lang="en">Competence is the need to control the outcomes and experience a sense of ability (mastery)</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>gc:SDT_Relatedness</IRI><Literal xml:lang="en">Relatedness is the need to be connected with others, iterate with them, and experience caring for them.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Achiever</IRI><Literal xml:lang="en">This archetype is more explicitly goal-oriented, motivated by long-term achievements.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Activity_Loop</IRI><Literal xml:lang="en">Loop of activities in a game-like context.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#BrainHex</IRI><Literal xml:lang="en">Typology of playing preferences motivated by combining existing findings from player research with neurobiological insights into the presumed underlying mechanisms</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#CategoryCompetition</IRI><Literal xml:lang="en">A target behavior category focused on competitive outcomes and achievement hierarchies.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#CategoryEffectiveness</IRI><Literal xml:lang="en">A target behavior category measuring the efficiency and quality of player actions.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#CategoryEnjoyment</IRI><Literal xml:lang="en">A target behavior category centered on player satisfaction and intrinsic motivation.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#CategoryExploration</IRI><Literal xml:lang="en">A target behavior category focused on discovery, curiosity, and world engagement.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#CategoryParticipation</IRI><Literal xml:lang="en">A target behavior category measuring engagement and involvement levels.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#CategoryPerformance</IRI><Literal xml:lang="en">A target behavior category assessing player skill execution and mastery.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Conqueror</IRI><Literal xml:lang="en">Players fitting the this archetype enjoy defeating impossibly difficult foes, struggling until they achieve victory, and beating other players.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Daredevil</IRI><Literal xml:lang="en">This play style is all about the thrill of the chase, the excitement of risk taking and generally playing on the edge.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#DesignPractice</IRI><Literal xml:lang="en">One or a set of game elements that leads a player to certain behaviors.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Engagement_Loop</IRI><Literal xml:lang="en">Engagement Loops (micro level; individual user action).</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#GamificationModel</IRI><Literal xml:lang="en">A complete model of gamification encompassing activity loops, engagement mechanics, and player affordances.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Mastemind</IRI><Literal xml:lang="en">Players who fit this archetype enjoy solving puzzles and devising strategies, as well as focusing on making the most efficient decisions.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Metric</IRI><Literal xml:lang="en">A standard of measurent for target behavior.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Motivational_Affordance</IRI><Literal>The term affordance can refer to any qualities of the service system that contributes to the emergence of gameful experience. (Huotari)</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Player_Action</IRI><Literal xml:lang="en">The actions of a player in a gamified context.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Progressive_Loop</IRI><Literal xml:lang="en">Progression Loops (macro level; broader structures of activity throughout the course of the game)</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Seeker</IRI><Literal xml:lang="en">Motivated by interest mechanism, which relates to the brain area processing sensory information and memory association.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Self-Determination_Theory</IRI><Literal xml:lang="en">An approach to human motivation and personality that uses traditional empirical methods while employing an organismic metatheory that highlights the importance of humans&apos; evolved inner resources for personality development and behavioral self-regulation</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Socializer</IRI><Literal xml:lang="en">People are a primary source of enjoyment for players fitting this archetype</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Survivor</IRI><Literal xml:lang="en">This archetype could be related to Lazzaro&apos;s serious fun, but in either case it can be seen as a special case of Caillois&apos; ilinx, which purposefully courts controlled experiences of panic</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Target_Behavior</IRI><Literal xml:lang="en">The expected behavior in the Fogg&apos;s Behavior Model.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Target_Behavior_Category</IRI><Literal xml:lang="en">A category of Target Behavior based on empirical data in the literature.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Achievement_Component</IRI><Literal xml:lang="en">A motivational component from Yee&apos;s taxonomy focused on advancement and goal achievement.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Advancement</IRI><Literal xml:lang="en">Players who derive satisfaction from reaching goals, leveling quickly and accumulating in-game resources such as gold.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Competition</IRI><Literal xml:lang="en">Players who enjoy competing with other gamers on the battlefield or economy.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Customization</IRI><Literal xml:lang="en">Players who enjoy customizing the appearance of their characters.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Discovery</IRI><Literal xml:lang="en">Players who enjoy exploring the world and discovering locations, quests or artifacts that others may not know about.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Escapism</IRI><Literal xml:lang="en">Players who use the environment as a place to relax or relieve their stress from the real world.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Immersion_Component</IRI><Literal xml:lang="en">A motivational component from Yee&apos;s taxonomy centered on story immersion and world exploration.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Mechanics</IRI><Literal xml:lang="en">Players who derive satisfaction from analyzing and understanding the underlying numerical mechanics of the system.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Relationship</IRI><Literal xml:lang="en">Players who are looking to form sustained, meaningful relationships with others.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Role-Playing</IRI><Literal xml:lang="en">Players who enjoy being immersed in a story through the eyes of a character that they designed.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Social_Component</IRI><Literal xml:lang="en">A motivational component from Yee&apos;s taxonomy focused on social interaction and relationships.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Socializing</IRI><Literal xml:lang="en">Players who enjoy meeting and getting to know other gamers</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yee_Teamwork</IRI><Literal xml:lang="en">Players who enjoy working and collaborating with others</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Yees_Motivational_Components</IRI><Literal xml:lang="en">Motivational components based on an extensive survey of MMORPG players.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#coversComponent</IRI><Literal xml:lang="en">Indicates that a player type is covered or characterized by a motivational component.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#hasActivityLoops</IRI><Literal xml:lang="en">Associates a gamification model with the activity loops it contains.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#hasCategory</IRI><Literal xml:lang="en">Associates a target behavior with its category classification.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#hasGameElement</IRI><Literal xml:lang="en">Specifies the game elements used in a design practice.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#hasMetric</IRI><Literal xml:lang="en">Associates a target behavior with the metrics that measure it.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#hasPlayer</IRI><Literal xml:lang="en">Associates a player action with the player performing it.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#hasTargetBehavior</IRI><Literal xml:lang="en">Specifies the intended behavior that a design practice aims to achieve.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#isAccomplishedWith</IRI><Literal xml:lang="en">Indicates the activity loop that accomplishes a target behavior.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#isComposedBy</IRI><Literal xml:lang="en">Indicates the components (feedback, affordances, actions) that compose an engagement loop.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#isMotivatedWith</IRI><Literal xml:lang="en">Associates a motivational component with the game elements that support it.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#isPartOfEngagementLoop</IRI><Literal xml:lang="en">Indicates that a component belongs to an engagement loop.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#isSatisfiedWith</IRI><Literal xml:lang="en">Indicates the game element that satisfies a self-determination theory need.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#isUsedFor</IRI><Literal xml:lang="en">Indicates the target behavior that a metric is used to measure.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#leadsTo</IRI><Literal xml:lang="en">Indicates the target behavior that an activity loop achieves.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#leadsToCompetition</IRI><Literal xml:lang="en">Indicates that a game element leads to competitive behavior.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#leadsToEffectiveness</IRI><Literal xml:lang="en">Indicates that a game element leads to improved effectiveness or performance quality.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#leadsToEnjoyment</IRI><Literal xml:lang="en">Indicates that a game element leads to increased enjoyment or satisfaction.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#leadsToExploration</IRI><Literal xml:lang="en">Indicates that a game element encourages exploration and discovery.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#leadsToParticipation</IRI><Literal xml:lang="en">Indicates that a game element leads to increased participation and engagement.</Literal></AnnotationAssertion>
    <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#leadsToPerformance</IRI><Literal xml:lang="en">Indicates that a game element leads to improved player performance.</Literal></AnnotationAssertion>
