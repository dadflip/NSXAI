<?xml version="1.0"?>
<Ontology xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://surveys.nees.com.br/ontologies/gado_full.owl"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     ontologyIRI="http://surveys.nees.com.br/ontologies/gado_full.owl">
    <Prefix name="" IRI="http://surveys.nees.com.br/ontologies/gado_full.owl#"/>
    <Prefix name="gc" IRI="http://surveys.nees.com.br/ontologies/gado_core.owl#"/>
    <Prefix name="gf" IRI="http://surveys.nees.com.br/ontologies/gado_full.owl#"/>
    <Prefix name="owl" IRI="http://www.w3.org/2002/07/owl#"/>
    <Prefix name="rdf" IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
    <Prefix name="xml" IRI="http://www.w3.org/XML/1998/namespace"/>
    <Prefix name="xsd" IRI="http://www.w3.org/2001/XMLSchema#"/>
    <Prefix name="rdfs" IRI="http://www.w3.org/2000/01/rdf-schema#"/>
    <Import>http://surveys.nees.com.br/ontologies/gado_core.owl</Import>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <Literal xml:lang="en">GADO Full extends GADO Core with player archetypes (Bartle, Yee), motivational affordances, activity loops, and design practices for gamification in educational ITS contexts.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <Literal xml:lang="en">GADO Full Ontology</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="owl:versionInfo"/>
        <Literal>1.1</Literal>
    </Annotation>

    <!-- ═══════════════════════════════════════════════════
         DECLARATIONS : classes propres à gado_full seulement
         Les classes de gado_core sont héritées via <Import>
         ═══════════════════════════════════════════════════ -->

    <!-- SDT (importées de gc: mais déclarées ici pour OWL API) -->
    <Declaration><Class IRI="gc:SDT_Autonomy"/></Declaration>
    <Declaration><Class IRI="gc:SDT_Competence"/></Declaration>
    <Declaration><Class IRI="gc:SDT_Relatedness"/></Declaration>

    <!-- Archetypes BrainHex -->
    <Declaration><Class IRI="#Achiever"/></Declaration>
    <Declaration><Class IRI="#BrainHex"/></Declaration>
    <Declaration><Class IRI="#Conqueror"/></Declaration>
    <Declaration><Class IRI="#Daredevil"/></Declaration>
    <Declaration><Class IRI="#Mastemind"/></Declaration>
    <Declaration><Class IRI="#Seeker"/></Declaration>
    <Declaration><Class IRI="#Socializer"/></Declaration>
    <Declaration><Class IRI="#Survivor"/></Declaration>

    <!-- Activity Loops -->
    <Declaration><Class IRI="#Activity_Loop"/></Declaration>
    <Declaration><Class IRI="#Engagement_Loop"/></Declaration>
    <Declaration><Class IRI="#Progressive_Loop"/></Declaration>

    <!-- Target Behavior -->
    <Declaration><Class IRI="#Target_Behavior"/></Declaration>
    <Declaration><Class IRI="#Target_Behavior_Category"/></Declaration>
    <Declaration><Class IRI="#CategoryCompetition"/></Declaration>
    <Declaration><Class IRI="#CategoryEffectiveness"/></Declaration>
    <Declaration><Class IRI="#CategoryEnjoyment"/></Declaration>
    <Declaration><Class IRI="#CategoryExploration"/></Declaration>
    <Declaration><Class IRI="#CategoryParticipation"/></Declaration>
    <Declaration><Class IRI="#CategoryPerformance"/></Declaration>

    <!-- Gamification model & design -->
    <Declaration><Class IRI="#GamificationModel"/></Declaration>
    <Declaration><Class IRI="#DesignPractice"/></Declaration>
    <Declaration><Class IRI="#Motivational_Affordance"/></Declaration>
    <Declaration><Class IRI="#Metric"/></Declaration>
    <Declaration><Class IRI="#Player_Action"/></Declaration>

    <!-- Motivation theories (propres à gado_full) -->
    <Declaration><Class IRI="#Self-Determination_Theory"/></Declaration>

    <!-- Yee's motivational components -->
    <Declaration><Class IRI="#Yees_Motivational_Components"/></Declaration>
    <Declaration><Class IRI="#Yee_Achievement_Component"/></Declaration>
    <Declaration><Class IRI="#Yee_Immersion_Component"/></Declaration>
    <Declaration><Class IRI="#Yee_Social_Component"/></Declaration>
    <Declaration><Class IRI="#Yee_Advancement"/></Declaration>
    <Declaration><Class IRI="#Yee_Competition"/></Declaration>
    <Declaration><Class IRI="#Yee_Mechanics"/></Declaration>
    <Declaration><Class IRI="#Yee_Customization"/></Declaration>
    <Declaration><Class IRI="#Yee_Discovery"/></Declaration>
    <Declaration><Class IRI="#Yee_Escapism"/></Declaration>
    <Declaration><Class IRI="#Yee_Role-Playing"/></Declaration>
    <Declaration><Class IRI="#Yee_Relationship"/></Declaration>
    <Declaration><Class IRI="#Yee_Socializing"/></Declaration>
    <Declaration><Class IRI="#Yee_Teamwork"/></Declaration>

    <!-- ═══════════════════════════════════════════════════
         OBJECT PROPERTIES (propres à gado_full)
         NB: describesType est déjà dans gado_core, pas re-déclaré
         ═══════════════════════════════════════════════════ -->
    <Declaration><ObjectProperty IRI="#coversComponent"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasActivityLoops"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasCategory"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasGameElement"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasMetric"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasPlayer"/></Declaration>
    <Declaration><ObjectProperty IRI="#hasTargetBehavior"/></Declaration>
    <Declaration><ObjectProperty IRI="#isAccomplishedWith"/></Declaration>
    <Declaration><ObjectProperty IRI="#isComposedBy"/></Declaration>
    <Declaration><ObjectProperty IRI="#isMotivatedWith"/></Declaration>
    <Declaration><ObjectProperty IRI="#isPartOfEngagementLoop"/></Declaration>
    <Declaration><ObjectProperty IRI="#isSatisfiedWith"/></Declaration>
    <Declaration><ObjectProperty IRI="#isUsedFor"/></Declaration>
    <Declaration><ObjectProperty IRI="#leadsTo"/></Declaration>
    <Declaration><ObjectProperty IRI="#leadsToCompetition"/></Declaration>
    <Declaration><ObjectProperty IRI="#leadsToEffectiveness"/></Declaration>
    <Declaration><ObjectProperty IRI="#leadsToEnjoyment"/></Declaration>
    <Declaration><ObjectProperty IRI="#leadsToExploration"/></Declaration>
    <Declaration><ObjectProperty IRI="#leadsToParticipation"/></Declaration>
    <Declaration><ObjectProperty IRI="#leadsToPerformance"/></Declaration>

    <!-- ═══════════════════════════════════════════════════
         DATA PROPERTIES
         ═══════════════════════════════════════════════════ -->
    <Declaration><DataProperty IRI="#competionName"/></Declaration>
    <Declaration><DataProperty IRI="#effectivenessName"/></Declaration>
    <Declaration><DataProperty IRI="#enjoymentName"/></Declaration>
    <Declaration><DataProperty IRI="#explorationName"/></Declaration>
    <Declaration><DataProperty IRI="#loopDifficulty"/></Declaration>
    <Declaration><DataProperty IRI="#loopQuality"/></Declaration>
    <Declaration><DataProperty IRI="#loopStatus"/></Declaration>
    <Declaration><DataProperty IRI="#metricDescription"/></Declaration>
    <Declaration><DataProperty IRI="#metricExpectedValue"/></Declaration>
    <Declaration><DataProperty IRI="#metricValue"/></Declaration>
    <Declaration><DataProperty IRI="#participationName"/></Declaration>
    <Declaration><DataProperty IRI="#performanceName"/></Declaration>

    <!-- ═══════════════════════════════════════════════════
         NAMED INDIVIDUALS
         ═══════════════════════════════════════════════════ -->
    <Declaration><NamedIndividual IRI="#effectiveness"/></Declaration>
    <Declaration><NamedIndividual IRI="#engagement"/></Declaration>
    <Declaration><NamedIndividual IRI="#enjoyment"/></Declaration>
    <Declaration><NamedIndividual IRI="#increaseHappiness"/></Declaration>
    <Declaration><NamedIndividual IRI="#increasePerformance"/></Declaration>
    <Declaration><NamedIndividual IRI="#interactionWithTheSystem"/></Declaration>
    <Declaration><NamedIndividual IRI="#motivation"/></Declaration>
    <Declaration><NamedIndividual IRI="#participation"/></Declaration>
    <Declaration><NamedIndividual IRI="#performance"/></Declaration>
    <Declaration><NamedIndividual IRI="#satisfaction"/></Declaration>
    <Declaration><NamedIndividual IRI="#signupForTheSystem"/></Declaration>
    <Declaration><NamedIndividual IRI="#testEngagementLoop"/></Declaration>

    <!-- ═══════════════════════════════════════════════════
         EQUIVALENCES
         ═══════════════════════════════════════════════════ -->
    <!-- Player_Action et Target_Behavior sont synonymes dans ce modèle -->
    <EquivalentClasses>
        <Class IRI="#Player_Action"/>
        <Class IRI="#Target_Behavior"/>
    </EquivalentClasses>

    <!-- ═══════════════════════════════════════════════════
         TAXONOMIE : Self-Determination Theory
         gc:SDT_* étendent #Self-Determination_Theory
         et sont satisfaites par des gc:GDE_Dynamic de gado_core
         ═══════════════════════════════════════════════════ -->
    <SubClassOf>
        <Class IRI="#Self-Determination_Theory"/>
        <Class abbreviatedIRI="gc:Motivation_And_Need_Theory"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="gc:SDT_Autonomy"/>
        <ObjectIntersectionOf>
            <Class IRI="#Self-Determination_Theory"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isSatisfiedWith"/>
                <ObjectUnionOf>
                    <Class abbreviatedIRI="gc:Narrative"/>
                    <Class abbreviatedIRI="gc:Progression"/>
                </ObjectUnionOf>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="gc:SDT_Competence"/>
        <ObjectIntersectionOf>
            <Class IRI="#Self-Determination_Theory"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isSatisfiedWith"/>
                <ObjectUnionOf>
                    <Class abbreviatedIRI="gc:Constraints"/>
                    <Class abbreviatedIRI="gc:Progression"/>
                </ObjectUnionOf>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="gc:SDT_Relatedness"/>
        <ObjectIntersectionOf>
            <Class IRI="#Self-Determination_Theory"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isSatisfiedWith"/>
                <ObjectUnionOf>
                    <Class abbreviatedIRI="gc:Emotions"/>
                    <Class abbreviatedIRI="gc:Relationships"/>
                </ObjectUnionOf>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>

    <!-- ═══════════════════════════════════════════════════
         TAXONOMIE : BrainHex archetypes
         ═══════════════════════════════════════════════════ -->
    <SubClassOf>
        <Class IRI="#BrainHex"/>
        <ObjectIntersectionOf>
            <Class abbreviatedIRI="gc:Player_Model"/>
            <ObjectAllValuesFrom>
                <ObjectProperty abbreviatedIRI="gc:describesType"/>
                <Class abbreviatedIRI="gc:Player_Type"/>
            </ObjectAllValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Achiever"/>
        <ObjectIntersectionOf>
            <Class abbreviatedIRI="gc:Player_Type"/>
            <ObjectAllValuesFrom>
                <ObjectProperty IRI="#coversComponent"/>
                <Class abbreviatedIRI="gc:Progression"/>
            </ObjectAllValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Conqueror"/>
        <ObjectIntersectionOf>
            <Class abbreviatedIRI="gc:Player_Type"/>
            <ObjectAllValuesFrom>
                <ObjectProperty IRI="#coversComponent"/>
                <ObjectUnionOf>
                    <Class abbreviatedIRI="gc:Progression"/>
                    <Class abbreviatedIRI="gc:Relationships"/>
                </ObjectUnionOf>
            </ObjectAllValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Daredevil"/>
        <ObjectIntersectionOf>
            <Class abbreviatedIRI="gc:Player_Type"/>
            <ObjectAllValuesFrom>
                <ObjectProperty IRI="#coversComponent"/>
                <Class abbreviatedIRI="gc:Emotions"/>
            </ObjectAllValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Mastemind"/>
        <ObjectIntersectionOf>
            <Class abbreviatedIRI="gc:Player_Type"/>
            <ObjectAllValuesFrom>
                <ObjectProperty IRI="#coversComponent"/>
                <Class abbreviatedIRI="gc:Constraints"/>
            </ObjectAllValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Seeker"/>
        <ObjectIntersectionOf>
            <Class abbreviatedIRI="gc:Player_Type"/>
            <ObjectAllValuesFrom>
                <ObjectProperty IRI="#coversComponent"/>
                <ObjectIntersectionOf>
                    <Class abbreviatedIRI="gc:Constraints"/>
                    <Class abbreviatedIRI="gc:Narrative"/>
                    <Class abbreviatedIRI="gc:Progression"/>
                </ObjectIntersectionOf>
            </ObjectAllValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Socializer"/>
        <ObjectIntersectionOf>
            <Class abbreviatedIRI="gc:Player_Type"/>
            <ObjectAllValuesFrom>
                <ObjectProperty IRI="#coversComponent"/>
                <Class abbreviatedIRI="gc:Relationships"/>
            </ObjectAllValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Survivor"/>
        <ObjectIntersectionOf>
            <Class abbreviatedIRI="gc:Player_Type"/>
            <ObjectAllValuesFrom>
                <ObjectProperty IRI="#coversComponent"/>
                <ObjectIntersectionOf>
                    <Class abbreviatedIRI="gc:Emotions"/>
                    <Class abbreviatedIRI="gc:Narrative"/>
                </ObjectIntersectionOf>
            </ObjectAllValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>

    <!-- ═══════════════════════════════════════════════════
         TAXONOMIE : Activity Loops
         ═══════════════════════════════════════════════════ -->
    <SubClassOf>
        <Class IRI="#Engagement_Loop"/>
        <Class IRI="#Activity_Loop"/>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Progressive_Loop"/>
        <Class IRI="#Activity_Loop"/>
    </SubClassOf>

    <!-- ═══════════════════════════════════════════════════
         TAXONOMIE : Target Behavior Categories
         ═══════════════════════════════════════════════════ -->
    <SubClassOf><Class IRI="#CategoryCompetition"/><Class IRI="#Target_Behavior_Category"/></SubClassOf>
    <SubClassOf><Class IRI="#CategoryEffectiveness"/><Class IRI="#Target_Behavior_Category"/></SubClassOf>
    <SubClassOf><Class IRI="#CategoryEnjoyment"/><Class IRI="#Target_Behavior_Category"/></SubClassOf>
    <SubClassOf><Class IRI="#CategoryExploration"/><Class IRI="#Target_Behavior_Category"/></SubClassOf>
    <SubClassOf><Class IRI="#CategoryParticipation"/><Class IRI="#Target_Behavior_Category"/></SubClassOf>
    <SubClassOf><Class IRI="#CategoryPerformance"/><Class IRI="#Target_Behavior_Category"/></SubClassOf>

    <!-- ═══════════════════════════════════════════════════
         TAXONOMIE : Yee's Motivational Components
         ═══════════════════════════════════════════════════ -->
    <SubClassOf>
        <Class IRI="#Yees_Motivational_Components"/>
        <Class abbreviatedIRI="gc:Player_Model"/>
    </SubClassOf>
    <SubClassOf><Class IRI="#Yee_Achievement_Component"/><Class IRI="#Yees_Motivational_Components"/></SubClassOf>
    <SubClassOf><Class IRI="#Yee_Immersion_Component"/><Class IRI="#Yees_Motivational_Components"/></SubClassOf>
    <SubClassOf><Class IRI="#Yee_Social_Component"/><Class IRI="#Yees_Motivational_Components"/></SubClassOf>

    <SubClassOf>
        <Class IRI="#Yee_Advancement"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Achievement_Component"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isMotivatedWith"/>
                <Class abbreviatedIRI="gc:Progression"/>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Yee_Competition"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Achievement_Component"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isMotivatedWith"/>
                <ObjectUnionOf>
                    <Class abbreviatedIRI="gc:Emotions"/>
                    <Class abbreviatedIRI="gc:Relationships"/>
                </ObjectUnionOf>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Yee_Mechanics"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Achievement_Component"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isMotivatedWith"/>
                <Class abbreviatedIRI="gc:Constraints"/>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Yee_Customization"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Immersion_Component"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isMotivatedWith"/>
                <Class abbreviatedIRI="gc:Narrative"/>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Yee_Discovery"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Immersion_Component"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isMotivatedWith"/>
                <Class abbreviatedIRI="gc:Progression"/>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Yee_Escapism"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Immersion_Component"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isMotivatedWith"/>
                <ObjectUnionOf>
                    <Class abbreviatedIRI="gc:Emotions"/>
                    <Class abbreviatedIRI="gc:Narrative"/>
                </ObjectUnionOf>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Yee_Role-Playing"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Immersion_Component"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isMotivatedWith"/>
                <ObjectUnionOf>
                    <Class abbreviatedIRI="gc:Constraints"/>
                    <Class abbreviatedIRI="gc:Narrative"/>
                </ObjectUnionOf>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Yee_Relationship"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Social_Component"/>
            <ObjectIntersectionOf>
                <ObjectSomeValuesFrom>
                    <ObjectProperty IRI="#isMotivatedWith"/>
                    <Class abbreviatedIRI="gc:Emotions"/>
                </ObjectSomeValuesFrom>
                <ObjectSomeValuesFrom>
                    <ObjectProperty IRI="#isMotivatedWith"/>
                    <Class abbreviatedIRI="gc:Relationships"/>
                </ObjectSomeValuesFrom>
            </ObjectIntersectionOf>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Yee_Socializing"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Social_Component"/>
            <ObjectSomeValuesFrom>
                <ObjectProperty IRI="#isMotivatedWith"/>
                <Class abbreviatedIRI="gc:Relationships"/>
            </ObjectSomeValuesFrom>
        </ObjectIntersectionOf>
    </SubClassOf>
    <SubClassOf>
        <Class IRI="#Yee_Teamwork"/>
        <ObjectIntersectionOf>
            <Class IRI="#Yee_Social_Component"/>
            <ObjectIntersectionOf>
                <ObjectSomeValuesFrom>
                    <ObjectProperty IRI="#isMotivatedWith"/>
                    <Class abbreviatedIRI="gc:Progression"/>
                </ObjectSomeValuesFrom>
                <ObjectSomeValuesFrom>
                    <ObjectProperty IRI="#isMotivatedWith"/>
                    <Class abbreviatedIRI="gc:Relationships"/>
                </ObjectSomeValuesFrom>
            </ObjectIntersectionOf>
        </ObjectIntersectionOf>
    </SubClassOf>

    <!-- ═══════════════════════════════════════════════════
         INSTANCE
         ═══════════════════════════════════════════════════ -->
    <ClassAssertion>
        <Class IRI="#Engagement_Loop"/>
        <NamedIndividual IRI="#testEngagementLoop"/>
    </ClassAssertion>

    <!-- ═══════════════════════════════════════════════════
         OBJECT PROPERTY AXIOMS
         ═══════════════════════════════════════════════════ -->
    <InverseObjectProperties>
        <ObjectProperty IRI="#hasMetric"/>
        <ObjectProperty IRI="#isUsedFor"/>
    </InverseObjectProperties>
    <InverseObjectProperties>
        <ObjectProperty IRI="#isAccomplishedWith"/>
        <ObjectProperty IRI="#leadsTo"/>
    </InverseObjectProperties>
    <InverseObjectProperties>
        <ObjectProperty IRI="#isComposedBy"/>
        <ObjectProperty IRI="#isPartOfEngagementLoop"/>
    </InverseObjectProperties>

    <!-- Domains -->
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#coversComponent"/>
        <Class abbreviatedIRI="gc:Player_Type"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#hasActivityLoops"/>
        <Class IRI="#GamificationModel"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#hasCategory"/>
        <Class IRI="#Target_Behavior"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#hasGameElement"/>
        <Class IRI="#DesignPractice"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#hasMetric"/>
        <Class IRI="#Target_Behavior"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#hasPlayer"/>
        <Class IRI="#Player_Action"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#hasTargetBehavior"/>
        <Class IRI="#DesignPractice"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#isAccomplishedWith"/>
        <Class IRI="#Target_Behavior"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#isComposedBy"/>
        <Class IRI="#Engagement_Loop"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#isMotivatedWith"/>
        <Class IRI="#Yees_Motivational_Components"/>
    </ObjectPropertyDomain>
    <!-- isPartOfEngagementLoop domain : intersection de classes core + gf -->
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#isPartOfEngagementLoop"/>
        <ObjectIntersectionOf>
            <Class abbreviatedIRI="gc:Feedback"/>
            <Class IRI="#Motivational_Affordance"/>
            <Class IRI="#Player_Action"/>
        </ObjectIntersectionOf>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#isSatisfiedWith"/>
        <Class IRI="#Self-Determination_Theory"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#isUsedFor"/>
        <Class IRI="#Metric"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#leadsTo"/>
        <Class IRI="#Activity_Loop"/>
    </ObjectPropertyDomain>
    <!-- leadsTo* : domains = classes de gado_core -->
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#leadsToCompetition"/>
        <Class abbreviatedIRI="gc:Leaderboards"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#leadsToEffectiveness"/>
        <Class abbreviatedIRI="gc:Badges"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#leadsToEffectiveness"/>
        <Class abbreviatedIRI="gc:Leaderboards"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#leadsToEnjoyment"/>
        <Class abbreviatedIRI="gc:Achievements"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#leadsToEnjoyment"/>
        <Class abbreviatedIRI="gc:Avatars"/>
    </ObjectPropertyDomain>
    <ObjectPropertyDomain>
        <ObjectProperty IRI="#leadsToEnjoyment"/>
        <Class abbreviatedIRI="gc:Badges"/>
    </ObjectPropertyDomain>
