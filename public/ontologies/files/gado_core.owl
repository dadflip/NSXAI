    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Achievements</IRI>
        <Literal xml:lang="en">Defined objectives</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Avatars</IRI>
        <Literal xml:lang="en">A virtual representation of a player’s character in a game. Common in role-playing games in which the player might take on the role of a magical creature or a medieval warrior.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Badges</IRI>
        <Literal xml:lang="en">A visual token of a achievement. Usually designed to look like the real-world analogs, such as Boy Scout badges or the Good Housekeeping seal</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Boss_Fights</IRI>
        <Literal xml:lang="en">A difficult fight against a high-level opponent, called a boss. Often marks the end of a level or a section of a game</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Challenges</IRI>
        <Literal xml:lang="en">Puzzles or other tasks that require effort to solve</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Chances</IRI>
        <Literal xml:lang="en">Elements of randomness</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Collections</IRI>
        <Literal xml:lang="en">Set of items or badges to accumulate</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Combat</IRI>
        <Literal xml:lang="en">A defined battle, typically short-lived</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Competition</IRI>
        <Literal xml:lang="en">One player or group wins, and the other loses</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Constraints</IRI>
        <Literal xml:lang="en">Limitations or forced trade-offs</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Content_Unlocking</IRI>
        <Literal xml:lang="en">Aspects available only when players reach objectives</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Cooperation</IRI>
        <Literal xml:lang="en">Players must work together to achieve a shared goal</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Emotions</IRI>
        <Literal xml:lang="en">Curiosity, competitiveness, frustration, happiness, and so on</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Feedback</IRI>
        <Literal xml:lang="en">Information about how the player is doing.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GDE_Component</IRI>
        <Literal xml:lang="en">A particular structure in a game, implementing the game’s mechanics and dynamics. Points and badges are examples of game components</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GDE_Dynamic</IRI>
        <Literal xml:lang="en">The conceptual structures underlying a game, such as the narrative and rules (constraints) that shape the game. These are the most abstract game elements. Players feel their effects but do not engage with them directly.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#GDE_Mechanic</IRI>
        <Literal xml:lang="en">The processes that drive forward the action in a game, such as feedback or turns. Game mechanics are the actions that implement higher-level game dynamics and manifest themselves in lower-level game components.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Game_Context</IRI>
        <Literal xml:lang="en">A broader context or environment where a game or gamified experience takes place.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Game_Design_Element</IRI>
        <Literal xml:lang="en">A design pattern that can be incorporated into a game. Game elements are the pieces that a game designer assembles in creating an engaging experience</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Gamification</IRI>
        <Literal xml:lang="en">Use of game design elements in non-game contexts.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Gamification_Context</IRI>
        <Literal xml:lang="en">Context of gamification refers to the core service or an activity being gamified</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Gifting</IRI>
        <Literal xml:lang="en">Opportunities to share resources with others</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Leaderboards</IRI>
        <Literal xml:lang="en">A ranked list of participants in a game, with the highest scores on top.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Levels</IRI>
        <Literal xml:lang="en">Defined steps in player progression</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Motivation</IRI>
        <Literal xml:lang="en">Motivation is literally the desire to do things.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Motivation_And_Need_Theory</IRI>
        <Literal xml:lang="en">A theory that links motivation, needs, and game design principles to explain player engagement.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Motivational_Component</IRI>
        <Literal xml:lang="en">A component of motivation that combines behavioral, affective, or cognitive drivers.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Narrative</IRI>
        <Literal xml:lang="en">A consistent, ongoing storyline</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Non-Game_Context</IRI>
        <Literal xml:lang="en">A real-world or service context that is not inherently a game but can be enriched with gamification.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Player</IRI>
        <Literal xml:lang="en">An individual or entity that engages with gamified content, performing actions and receiving feedback.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Player_Model</IRI>
        <Literal xml:lang="en">A conceptual model describing player characteristics, preferences, or behavior patterns.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Player_Type</IRI>
        <Literal xml:lang="en">A classification of players based on behavior, motivation, or play style.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Points</IRI>
        <Literal xml:lang="en">Numerical representations of game progression</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Progression</IRI>
        <Literal xml:lang="en">The player’s growth and development</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Quests</IRI>
        <Literal xml:lang="en">A specific mission or challenge for players of a game. The quest will usually have a narrative and an objective and a reward for completion.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Relationships</IRI>
        <Literal xml:lang="en">Social interactions generating feelings of camaraderie, status, altruism, and so on</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Resource_Acquisition</IRI>
        <Literal xml:lang="en">Obtaining useful or collectible items</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Rewards</IRI>
        <Literal xml:lang="en">Benefits for some action or achievement</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Social_Graph</IRI>
        <Literal xml:lang="en">The network of relationships among friends, such as the matrix of connections on Facebook or other social networking sites.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Status</IRI>
        <Literal xml:lang="en">The rank or level of a player. Players are often motivated by trying to reach a higher level or status. </Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Story</IRI>
        <Literal xml:lang="en">A narrative structure used to give meaning, context, and progression to gamified experiences.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Teams</IRI>
        <Literal xml:lang="en">Defined groups of players working together for a common goal</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Theme</IRI>
        <Literal xml:lang="en">A visual or conceptual setting that gives coherence to the gamified experience.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Time_Constraints</IRI>
        <Literal xml:lang="en">Restrictions on time that shape how players engage with the gamified experience.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Transactions</IRI>
        <Literal xml:lang="en">Trading between players, directly or through intermediaries</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Turns</IRI>
        <Literal xml:lang="en">Sequential participation by alternating players</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Virtual_Goods</IRI>
        <Literal xml:lang="en">Virtual items that have value or uniqueness within a game environment. Players may be able to purchase virtual goods with virtual currency, real money, or through achievements within the game. Also called virtual assets.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Win_States</IRI>
        <Literal xml:lang="en">The outcomes of a game that constitute “winning”. Typically defined by the rules of the game and the game’s feedback or rewards mechanisms.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#affordsMotivation</IRI>
        <Literal xml:lang="en">Relates a game design element or mechanic to the type of motivation it supports.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#archetypeBehavior</IRI>
        <Literal xml:lang="en">Describes the typical behavior associated with a player archetype.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#archetypeBrainRegion</IRI>
        <Literal xml:lang="en">Describes the brain region or cognitive area associated with an archetype.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#archetypeChemicalMessenger</IRI>
        <Literal xml:lang="en">Describes the neurotransmitter or chemical messenger linked to an archetype.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#archetypeLikes</IRI>
        <Literal xml:lang="en">Describes what an archetype prefers, values, or is drawn to.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#autonomy</IRI>
        <Literal xml:lang="en">A motivational construct related to self-determination, choice, and control.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#business</IRI>
        <Literal xml:lang="en">A non-game context where gamification applies to commercial or corporate settings.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#classifiesPlayer</IRI>
        <Literal xml:lang="en">Indicates that a player is assigned to a particular player model or type.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#composesDynamic</IRI>
        <Literal xml:lang="en">Connects a game mechanic to the higher-level dynamic it composes.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#computer-supported_cooperative_work</IRI>
        <Literal xml:lang="en">A non-game context involving collaborative computer-mediated work.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#computer_science_and_engineering</IRI>
        <Literal xml:lang="en">A non-game context related to STEM fields and engineering education.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#crowdsourcing</IRI>
        <Literal xml:lang="en">A non-game context where tasks are distributed to a broad crowd of participants.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#describesPlayer</IRI>
        <Literal xml:lang="en">Associates a player with descriptive characteristics or metadata.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#describesType</IRI>
        <Literal xml:lang="en">Links a type or model to the characteristics that describe it.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#education</IRI>
        <Literal xml:lang="en">A non-game context related to teaching and learning scenarios.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#facilitators</IRI>
        <Literal xml:lang="en">A non-game context representing support actors or enabling services.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#financial</IRI>
        <Literal xml:lang="en">A non-game context related to economic incentives or monetary systems.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#food</IRI>
        <Literal xml:lang="en">A non-game context related to nutrition, meals, or food services.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#hasGamification</IRI>
        <Literal xml:lang="en">Indicates that a non-game context includes gamification elements.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#hasPlayerInteraction</IRI>
        <Literal xml:lang="en">Indicates that a gamification context provides a place for a player to interact.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#health-care</IRI>
        <Literal xml:lang="en">A non-game context related to health, medicine, and wellness.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#interactsIn</IRI>
        <Literal xml:lang="en">Specifies the gamification context in which a player interacts.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#isAppliedTo</IRI>
        <Literal xml:lang="en">Identifies the object or context to which gamification is applied.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#isClassifiedBy</IRI>
        <Literal xml:lang="en">Indicates the model or classifier used to categorize a player.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#isComprisedOf</IRI>
        <Literal xml:lang="en">Indicates that a motivation or model is composed of smaller components.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#isDescribedByModel</IRI>
        <Literal xml:lang="en">Specifies the player model that describes a particular player type.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#isDescribedByType</IRI>
        <Literal xml:lang="en">Specifies the player type that is used to describe a player.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#isTiedTo</IRI>
        <Literal xml:lang="en">Relates a game design element to the component or mechanic it supports.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#isUsedBy</IRI>
        <Literal xml:lang="en">Identifies the higher-level element that uses the given game element.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#makesUseOf</IRI>
        <Literal xml:lang="en">Indicates that one concept makes use of another for game behavior or motivation.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#marketing</IRI>
        <Literal xml:lang="en">A non-game context related to customer engagement and promotion.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#mastery</IRI>
        <Literal xml:lang="en">A motivational construct related to competence and skill growth.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#orientation</IRI>
        <Literal xml:lang="en">A non-game context related to onboarding and introductory processes.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#personal</IRI>
        <Literal xml:lang="en">A non-game context related to individual or personal use cases.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#power</IRI>
        <Literal xml:lang="en">A motivational construct related to influence, control, and leadership.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#purpose</IRI>
        <Literal xml:lang="en">A motivational construct related to meaningful goals and contribution.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
