    ns1:metricExpectedValue "87.63"^^xsd:float ;
    ns1:metricValue "23.69"^^xsd:float .

<http://nsxai.org/instances#metric_0560> a ns1:Metric,
        owl:NamedIndividual ;
    ns1:metricDescription "time_on_task"^^xsd:string ;
    ns1:metricExpectedValue "94.42"^^xsd:float ;
    ns1:metricValue "36.11"^^xsd:float .

ns4:Gamification a owl:Class ;
    rdfs:comment "Use of game design elements in non-game contexts."@en .

ns4:Gamification_Context a owl:Class ;
    rdfs:comment "Context of gamification refers to the core service or an activity being gamified"@en .

ns1:Self-Determination_Theory a owl:Class ;
    rdfs:comment "An approach to human motivation and personality that uses traditional empirical methods while employing an organismic metatheory that highlights the importance of humans' evolved inner resources for personality development and behavioral self-regulation"@en ;
    rdfs:subClassOf ns4:Motivation_And_Need_Theory .

ns1:Yee_Immersion_Component a owl:Class ;
    rdfs:comment "A motivational component from Yee's taxonomy centered on story immersion and world exploration."@en ;
    rdfs:subClassOf ns1:Yees_Motivational_Components .

ns1:Yees_Motivational_Components a owl:Class ;
    rdfs:comment "Motivational components based on an extensive survey of MMORPG players."@en ;
    rdfs:subClassOf ns4:Player_Model .

ns3:THINGInstrutionalPlan a owl:Class ;
    rdfs:subClassOf ns3:THINGPedagogicalModel .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit> a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge> ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge> ],
        <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnOption> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> .

<http://nsxai.org/instances#gamModel_0015> a ns1:GamificationModel,
        owl:NamedIndividual ;
    ns1:hasActivityLoops <http://nsxai.org/instances#engLoop_0015>,
        <http://nsxai.org/instances#progLoop_0015> .

<http://nsxai.org/instances#metric_0105> a ns1:Metric,
        owl:NamedIndividual ;
    ns1:metricDescription "response_time"^^xsd:string ;
    ns1:metricExpectedValue "45.36"^^xsd:float ;
    ns1:metricValue "13.57"^^xsd:float .

<http://nsxai.org/instances#metric_0136> a ns1:Metric,
        owl:NamedIndividual ;
    ns1:metricDescription "mastery_level"^^xsd:string ;
    ns1:metricExpectedValue "54.84"^^xsd:float ;
    ns1:metricValue "63.31"^^xsd:float .

<http://nsxai.org/instances#metric_0178> a ns1:Metric,
        owl:NamedIndividual ;
    ns1:metricDescription "hints_used"^^xsd:string ;
    ns1:metricExpectedValue "83.34"^^xsd:float ;
    ns1:metricValue "50.03"^^xsd:float .

<http://nsxai.org/instances#metric_0440> a ns1:Metric,
        owl:NamedIndividual ;
    ns1:metricDescription "time_on_task"^^xsd:string ;
    ns1:metricExpectedValue "71.69"^^xsd:float ;
    ns1:metricValue "68.03"^^xsd:float .

<http://nsxai.org/instances#metric_0524> a ns1:Metric,
        owl:NamedIndividual ;
    ns1:metricDescription "attempts"^^xsd:string ;
    ns1:metricExpectedValue "84.53"^^xsd:float ;
    ns1:metricValue "8.27"^^xsd:float .

ns1:Activity_Loop a owl:Class ;
    rdfs:comment "Loop of activities in a game-like context."@en .

ns1:Player_Action a owl:Class ;
    rdfs:comment "The actions of a player in a gamified context."@en .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Activity> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Content> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#WritingEvaluation> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource> .

<http://nsxai.org/instances#metric_0276> a ns1:Metric,
        owl:NamedIndividual ;
    ns1:metricDescription "accuracy"^^xsd:string ;
    ns1:metricExpectedValue "98.91"^^xsd:float ;
    ns1:metricValue "51.54"^^xsd:float .

ns4:GDE_Dynamic a owl:Class ;
    rdfs:comment "The conceptual structures underlying a game, such as the narrative and rules (constraints) that shape the game. These are the most abstract game elements. Players feel their effects but do not engage with them directly."@en ;
    rdfs:subClassOf ns4:Game_Design_Element .

ns4:Player_Model a owl:Class ;
    rdfs:comment "A conceptual model describing player characteristics, preferences, or behavior patterns."@en .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> .

ns1:Target_Behavior_Category a owl:Class ;
    rdfs:comment "A category of Target Behavior based on empirical data in the literature."@en .

ns1:coversComponent a owl:ObjectProperty ;
    rdfs:comment "Indicates that a player type is covered or characterized by a motivational component."@en ;
    rdfs:domain ns4:Player_Type ;
    rdfs:range ns4:Game_Design_Element .

ns3:ResourceUnit a owl:Class ;
    rdfs:subClassOf ns3:Sequencing .

ns4:Motivation a owl:Class ;
    rdfs:comment "Motivation is literally the desire to do things."@en .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

ns4:Game_Design_Element a owl:Class ;
    rdfs:comment "A design pattern that can be incorporated into a game. Game elements are the pieces that a game designer assembles in creating an engaging experience"@en .

ns1:isMotivatedWith a owl:ObjectProperty ;
    rdfs:comment "Associates a motivational component with the game elements that support it."@en ;
    rdfs:domain ns1:Yees_Motivational_Components ;
    rdfs:range ns4:Game_Design_Element .

ns4:Player_Type a owl:Class ;
    rdfs:comment "A classification of players based on behavior, motivation, or play style."@en .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#DomainModel> .

ns4:GDE_Mechanic a owl:Class ;
    rdfs:comment "The processes that drive forward the action in a game, such as feedback or turns. Game mechanics are the actions that implement higher-level game dynamics and manifest themselves in lower-level game components."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty ns4:tiesComponent ;
            owl:someValuesFrom ns4:GDE_Component ],
        ns4:Game_Design_Element .

ns4:Non-Game_Context a owl:Class ;
    rdfs:comment "A real-world or service context that is not inherently a game but can be enriched with gamification."@en ;
    rdfs:subClassOf ns4:Gamification_Context .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

ns4:GDE_Component a owl:Class ;
    rdfs:comment "A particular structure in a game, implementing the game’s mechanics and dynamics. Points and badges are examples of game components"@en ;
    rdfs:subClassOf ns4:Game_Design_Element .

ns4:Chances a owl:Class ;
    rdfs:comment "Elements of randomness"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Constraints ns4:Emotions ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Collections a owl:Class ;
    rdfs:comment "Set of items or badges to accumulate"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Resource_Acquisition ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Combat a owl:Class ;
    rdfs:comment "A defined battle, typically short-lived"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Competition ns4:Turns ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Content_Unlocking a owl:Class ;
    rdfs:comment "Aspects available only when players reach objectives"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Rewards ns4:Win_States ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Gifting a owl:Class ;
    rdfs:comment "Opportunities to share resources with others"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Transactions ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Social_Graph a owl:Class ;
    rdfs:comment "The network of relationships among friends, such as the matrix of connections on Facebook or other social networking sites."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Cooperation ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Teams a owl:Class ;
    rdfs:comment "Defined groups of players working together for a common goal"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Competition ns4:Cooperation ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Time_Constraints a owl:Class ;
    rdfs:comment "Restrictions on time that shape how players engage with the gamified experience."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Challenges ns4:Competition ns4:Win_States ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Virtual_Goods a owl:Class ;
    rdfs:comment "Virtual items that have value or uniqueness within a game environment. Players may be able to purchase virtual goods with virtual currency, real money, or through achievements within the game. Also called virtual assets."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Resource_Acquisition ns4:Transactions ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns1:Daredevil a owl:Class ;
    rdfs:comment "This play style is all about the thrill of the chase, the excitement of risk taking and generally playing on the edge."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:Player_Type [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Emotions ;
                        owl:onProperty ns1:coversComponent ] ) ] .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum> a owl:Class .

ns4:Avatars a owl:Class ;
    rdfs:comment "A virtual representation of a player’s character in a game. Common in role-playing games in which the player might take on the role of a magical creature or a medieval warrior."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Feedback ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Boss_Fights a owl:Class ;
    rdfs:comment "A difficult fight against a high-level opponent, called a boss. Often marks the end of a level or a section of a game"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Challenges ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Quests a owl:Class ;
    rdfs:comment "A specific mission or challenge for players of a game. The quest will usually have a narrative and an objective and a reward for completion."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Challenges ns4:Cooperation ns4:Rewards ns4:Story ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Status a owl:Class ;
    rdfs:comment "The rank or level of a player. Players are often motivated by trying to reach a higher level or status. "@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Emotions ns4:Progression ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Turns a owl:Class ;
    rdfs:comment "Sequential participation by alternating players"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Constraints ns4:Progression ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Points a owl:Class ;
    rdfs:comment "Numerical representations of game progression"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Competition ns4:Resource_Acquisition ns4:Rewards ns4:Win_States ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Transactions a owl:Class ;
    rdfs:comment "Trading between players, directly or through intermediaries"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Progression ns4:Relationships ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Achievements a owl:Class ;
    rdfs:comment "Defined objectives"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Challenges ns4:Win_States ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Cooperation a owl:Class ;
    rdfs:comment "Players must work together to achieve a shared goal"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Relationships ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Levels a owl:Class ;
    rdfs:comment "Defined steps in player progression"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Competition ns4:Status ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Resource_Acquisition a owl:Class ;
    rdfs:comment "Obtaining useful or collectible items"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Progression ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Story a owl:Class ;
    rdfs:comment "A narrative structure used to give meaning, context, and progression to gamified experiences."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Narrative ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Theme a owl:Class ;
    rdfs:comment "A visual or conceptual setting that gives coherence to the gamified experience."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Narrative ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Badges a owl:Class ;
    rdfs:comment "A visual token of a achievement. Usually designed to look like the real-world analogs, such as Boy Scout badges or the Good Housekeeping seal"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Challenges ns4:Feedback ns4:Rewards ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Leaderboards a owl:Class ;
    rdfs:comment "A ranked list of participants in a game, with the highest scores on top."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Component [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Competition ns4:Feedback ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Win_States a owl:Class ;
    rdfs:comment "The outcomes of a game that constitute “winning”. Typically defined by the rules of the game and the game’s feedback or rewards mechanisms."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Constraints ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Competition a owl:Class ;
    rdfs:comment "One player or group wins, and the other loses"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Constraints ns4:Relationships ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Feedback a owl:Class ;
    rdfs:comment "Information about how the player is doing."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Progression ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Rewards a owl:Class ;
    rdfs:comment "Benefits for some action or achievement"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Emotions ns4:Progression ) ] ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns1:Seeker a owl:Class ;
    rdfs:comment "Motivated by interest mechanism, which relates to the brain area processing sensory information and memory association."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:Player_Type [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( ns4:Constraints ns4:Narrative ns4:Progression ) ] ;
                        owl:onProperty ns1:coversComponent ] ) ] .

ns1:Survivor a owl:Class ;
    rdfs:comment "This archetype could be related to Lazzaro's serious fun, but in either case it can be seen as a special case of Caillois' ilinx, which purposefully courts controlled experiences of panic"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:Player_Type [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( ns4:Emotions ns4:Narrative ) ] ;
                        owl:onProperty ns1:coversComponent ] ) ] .

ns4:Challenges a owl:Class ;
    rdfs:comment "Puzzles or other tasks that require effort to solve"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:GDE_Mechanic [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Constraints ;
                        owl:onProperty ns4:isTiedTo ] ) ] .

ns4:Narrative a owl:Class ;
    rdfs:comment "A consistent, ongoing storyline"@en ;
    rdfs:subClassOf ns4:GDE_Dynamic .

ns4:isTiedTo a owl:ObjectProperty ;
    rdfs:comment "Relates a game design element to the component or mechanic it supports."@en ;
    rdfs:domain ns4:GDE_Component ;
    rdfs:range ns4:GDE_Mechanic ;
    owl:inverseOf ns4:tiesComponent .

ns1:Achiever a owl:Class ;
    rdfs:comment "This archetype is more explicitly goal-oriented, motivated by long-term achievements."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:Player_Type [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Progression ;
                        owl:onProperty ns1:coversComponent ] ) ] .

ns4:Emotions a owl:Class ;
    rdfs:comment "Curiosity, competitiveness, frustration, happiness, and so on"@en ;
    rdfs:subClassOf ns4:GDE_Dynamic .

ns4:Constraints a owl:Class ;
    rdfs:comment "Limitations or forced trade-offs"@en ;
    rdfs:subClassOf ns4:GDE_Dynamic .

ns4:Relationships a owl:Class ;
    rdfs:comment "Social interactions generating feelings of camaraderie, status, altruism, and so on"@en ;
    rdfs:subClassOf ns4:GDE_Dynamic .

ns1:Conqueror a owl:Class ;
    rdfs:comment "Players fitting the this archetype enjoy defeating impossibly difficult foes, struggling until they achieve victory, and beating other players."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:Player_Type [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Progression ns4:Relationships ) ] ;
                        owl:onProperty ns1:coversComponent ] ) ] .

ns1:Mastermind a owl:Class ;
    rdfs:comment "Players who fit this archetype enjoy solving puzzles and devising strategies, as well as focusing on making the most efficient decisions."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:Player_Type [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Constraints ;
                        owl:onProperty ns1:coversComponent ] ) ] .

ns1:Socializer a owl:Class ;
    rdfs:comment "People are a primary source of enjoyment for players fitting this archetype"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:Player_Type [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Relationships ;
                        owl:onProperty ns1:coversComponent ] ) ] .

ns4:Progression a owl:Class ;
    rdfs:comment "The player’s growth and development"@en ;
    rdfs:subClassOf ns4:GDE_Dynamic .

ns1:Progressive_Loop a owl:Class ;
    rdfs:comment "Progression Loops (macro level; broader structures of activity throughout the course of the game)"@en ;
    rdfs:subClassOf ns1:Activity_Loop .

ns1:GamificationModel a owl:Class ;
    rdfs:comment "A complete model of gamification encompassing activity loops, engagement mechanics, and player affordances."@en .

ns1:Engagement_Loop a owl:Class ;
    rdfs:comment "Engagement Loops (micro level; individual user action)."@en ;
    rdfs:subClassOf ns1:Activity_Loop .

ns1:DesignPractice a owl:Class ;
    rdfs:comment "One or a set of game elements that leads a player to certain behaviors."@en .

ns2:GamifiedITS a owl:Class .

ns1:BrainHex a owl:Class ;
    rdfs:comment "Typology of playing preferences motivated by combining existing findings from player research with neurobiological insights into the presumed underlying mechanisms"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns4:Player_Model [ a owl:Restriction ;
                        owl:allValuesFrom ns4:Player_Type ;
                        owl:onProperty ns4:describesType ] ) ] .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

ns2:StudentModel a owl:Class .

ns3:InstrutionalPlan a owl:Class ;
    rdfs:comment "Instructional Plan Strategy."@en ;
    rdfs:subClassOf ns3:PedagogicalModel .

ns3:Sequencing a owl:Class ;
    rdfs:comment "A Sequencing is a map that represents the intended use of the content through structured units of instruction (curriculum)."@en ;
    rdfs:subClassOf ns3:THINGInstrutionalPlan .

ns3:Tactic a owl:Class ;
    rdfs:comment "Represents all the actions the educational system can do in order to teach."@en ;
    rdfs:subClassOf ns3:PedagogicalModel .

ns4:Player a owl:Class ;
    rdfs:comment "An individual or entity that engages with gamified content, performing actions and receiving feedback."@en .

ns3:Strategy a owl:Class ;
    rdfs:comment "Represents the teaching  mechanism in the instrutional plan."@en ;
    rdfs:subClassOf ns3:PedagogicalModel .

ns1:Target_Behavior a owl:Class ;
    rdfs:comment "The expected behavior in the Fogg's Behavior Model."@en ;
    owl:equivalentClass ns1:Player_Action .

ns1:Metric a owl:Class ;
    rdfs:comment "A standard of measurent for target behavior."@en .

[] a owl:AllDisjointClasses ;
    owl:members ( ns4:Constraints ns4:Emotions ns4:Narrative ns4:Progression ns4:Relationships ) .

[] a owl:AllDisjointClasses ;
    owl:members ( ns4:Achievements ns4:Avatars ns4:Badges ns4:Boss_Fights ns4:Collections ns4:Combat ns4:Content_Unlocking ns4:Gifting ns4:Leaderboards ns4:Levels ns4:Points ns4:Quests ns4:Social_Graph ns4:Teams ns4:Time_Constraints ns4:Virtual_Goods ) .

[] a owl:AllDisjointClasses ;
    owl:members ( ns4:Challenges ns4:Chances ns4:Competition ns4:Cooperation ns4:Feedback ns4:Resource_Acquisition ns4:Rewards ns4:Status ns4:Theme ns4:Transactions ns4:Turns ns4:Win_States ) .

