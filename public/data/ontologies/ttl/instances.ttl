ns4:tiesComponent a owl:ObjectProperty ;
    rdfs:comment "Specifies that a mechanic connects to or supports a game component."@en ;
    rdfs:domain ns4:GDE_Mechanic ;
    rdfs:range ns4:GDE_Component .

ns1:CategoryCompetition a owl:Class ;
    rdfs:comment "A target behavior category focused on competitive outcomes and achievement hierarchies."@en ;
    rdfs:subClassOf ns1:Target_Behavior_Category .

ns1:CategoryEffectiveness a owl:Class ;
    rdfs:comment "A target behavior category measuring the efficiency and quality of player actions."@en ;
    rdfs:subClassOf ns1:Target_Behavior_Category .

ns1:CategoryEnjoyment a owl:Class ;
    rdfs:comment "A target behavior category centered on player satisfaction and intrinsic motivation."@en ;
    rdfs:subClassOf ns1:Target_Behavior_Category .

ns1:CategoryExploration a owl:Class ;
    rdfs:comment "A target behavior category focused on discovery, curiosity, and world engagement."@en ;
    rdfs:subClassOf ns1:Target_Behavior_Category .

ns1:CategoryParticipation a owl:Class ;
    rdfs:comment "A target behavior category measuring engagement and involvement levels."@en ;
    rdfs:subClassOf ns1:Target_Behavior_Category .

ns1:CategoryPerformance a owl:Class ;
    rdfs:comment "A target behavior category assessing player skill execution and mastery."@en ;
    rdfs:subClassOf ns1:Target_Behavior_Category .

ns1:Motivational_Affordance a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#CKCurriculumInformation> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ResourceWeight> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge> a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit> <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception> ) ] ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Concept> a owl:Class ;
