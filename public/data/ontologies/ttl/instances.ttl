<http://surveys.nees.com.br/ontologies/gado_core.owl> a owl:Ontology ;
    rdfs:label "GADO Core Ontology"@en .

ns4:Motivational_Component a owl:Class ;
    rdfs:comment "A component of motivation that combines behavioral, affective, or cognitive drivers."@en .

ns4:describesType a owl:ObjectProperty ;
    rdfs:comment "Links a type or model to the characteristics that describe it."@en ;
    rdfs:domain ns4:Player_Model ;
    rdfs:range ns4:Player_Type ;
    owl:inverseOf ns4:isDescribedByModel .

ns4:interactsIn a owl:ObjectProperty ;
    rdfs:comment "Specifies the gamification context in which a player interacts."@en ;
    rdfs:domain ns4:Player ;
    rdfs:range ns4:Gamification_Context .

ns4:isAppliedTo a owl:ObjectProperty ;
    rdfs:comment "Identifies the object or context to which gamification is applied."@en ;
    rdfs:domain ns4:Gamification ;
    rdfs:range ns4:Non-Game_Context .

ns4:isClassifiedBy a owl:ObjectProperty ;
    rdfs:comment "Indicates the model or classifier used to categorize a player."@en ;
    rdfs:domain ns4:Player ;
    rdfs:range ns4:Player_Model .

ns4:isDescribedByModel a owl:ObjectProperty ;
    rdfs:comment "Specifies the player model that describes a particular player type."@en ;
    rdfs:domain ns4:Player_Type ;
    rdfs:range ns4:Player_Model .

ns4:isDescribedByType a owl:ObjectProperty ;
    rdfs:comment "Specifies the player type that is used to describe a player."@en ;
    rdfs:domain ns4:Player ;
    rdfs:range ns4:Player_Type .

ns4:makesUseOf a owl:ObjectProperty ;
    rdfs:comment "Indicates that one concept makes use of another for game behavior or motivation."@en ;
    rdfs:domain ns4:Gamification ;
    rdfs:range ns4:Game_Design_Element,
        ns4:Motivation_And_Need_Theory .

<http://surveys.nees.com.br/ontologies/gado_full.owl> a owl:Ontology ;
    rdfs:label "GADO Full Ontology"@en ;
    rdfs:comment "GADO Full extends GADO Core with player archetypes (Bartle, Yee), motivational affordances, activity loops, and design practices for gamification in educational ITS contexts."@en ;
    owl:imports <http://surveys.nees.com.br/ontologies/gado_core.owl> ;
    owl:versionInfo "1.1"^^xsd:string .

ns1:isPartOfEngagementLoop a owl:ObjectProperty ;
    rdfs:comment "Indicates that a component belongs to an engagement loop."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( ns4:Feedback ns1:Motivational_Affordance ns1:Player_Action ) ] ;
    rdfs:range ns1:Engagement_Loop .

ns1:isUsedFor a owl:ObjectProperty ;
    rdfs:comment "Indicates the target behavior that a metric is used to measure."@en ;
    rdfs:domain ns1:Metric ;
    rdfs:range ns1:Target_Behavior .

ns1:leadsTo a owl:ObjectProperty ;
    rdfs:comment "Indicates the target behavior that an activity loop achieves."@en ;
    rdfs:domain ns1:Activity_Loop ;
    rdfs:range ns1:Target_Behavior .

<http://surveys.nees.com.br/ontologies/gato.owl> a owl:Ontology ;
    rdfs:label "GATO - Gamified ITS Ontology"@en ;
    rdfs:comment """
            GATO integrates GADO Full (gamification) with the ITS Pedagogical ontology
            to model a complete Gamified Intelligent Tutoring System.
            Defines GamifiedITS and StudentModel, and reuses GamificationModel from GADO Full.
        """@en ;
    owl:imports <http://surveys.nees.com.br/ontologies/gado_full.owl>,
        <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl> ;
    owl:versionIRI <http://surveys.nees.com.br/ontologies/gato.owl/1.0> ;
    owl:versionInfo "1.0-fixed"^^xsd:string .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl> a owl:Ontology ;
    rdfs:label "ITS Pedagogical Ontology"@en ;
    rdfs:comment "Defines pedagogical models for Intelligent Tutoring Systems: instructional plans, sequencing strategies, tactics, and curriculum units."@en ;
    owl:imports <http://surveys.nees.com.br/ontologies/its_domain.owl> .

ns3:THINGPedagogicalModel a owl:Class .

ns3:isChildOf_Strategy a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain ns3:Strategy ;
    rdfs:range ns3:Strategy ;
    owl:inverseOf ns3:isParentOf_Strategy .

ns3:isChildOf_Tactic a owl:ObjectProperty ;
    rdfs:domain ns3:Tactic ;
    rdfs:range ns3:Tactic ;
    owl:inverseOf ns3:isParentOf_Tactic .

ns3:isParentOf_Strategy a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain ns3:Strategy ;
    rdfs:range ns3:Strategy ;
    owl:inverseOf ns3:isChildOf_Strategy .

ns3:isParentOf_Tactic a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain ns3:Tactic ;
    rdfs:range ns3:Tactic ;
    owl:inverseOf ns3:isChildOf_Tactic .

ns3:next_Curriculum a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain ns3:CurriculumUnit ;
    rdfs:range ns3:CurriculumUnit .

<http://surveys.nees.com.br/ontologies/its_domain.owl> a owl:Ontology ;
    rdfs:label "ITS Domain Ontology"@en ;
    rdfs:comment """
      Consolidated ITS domain ontology covering courses, knowledge domains, curriculum,
      pedagogical units, and learning resources. Derived from MeuTutor domain ontologies.
      The pedagogical layer (strategies, tactics, instructional plans) is defined separately
      in its.pedagogical.owl, which imports this ontology.
    """@en ;
    owl:versionInfo "1.1"^^xsd:string .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug_Misconception> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Bug> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Misconception> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#GenericOperator> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge> a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug> <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit> <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#UniversalGenericOperator> ) ] ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#FillBlanksOption> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceOption> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceProblem> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#TrueOrFalseOption> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> .

