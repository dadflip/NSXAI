<http://rdfs.org/sioc/ns#UserAccount> a owl:Class ;
    rdfs:comment "A user account (student or instructor) in the ITS platform (from SIOC vocabulary)."@en .

ns4:Game_Context a owl:Class ;
    rdfs:comment "A broader context or environment where a game or gamified experience takes place."@en ;
    rdfs:subClassOf ns4:Gamification_Context .

ns4:affordsMotivation a owl:ObjectProperty ;
    rdfs:comment "Relates a game design element or mechanic to the type of motivation it supports."@en ;
    rdfs:domain ns4:Game_Design_Element ;
    rdfs:range ns4:Motivation .

ns4:archetypeBehavior a owl:DatatypeProperty ;
    rdfs:comment "Describes the typical behavior associated with a player archetype."@en ;
    rdfs:range xsd:string .

ns4:archetypeBrainRegion a owl:DatatypeProperty ;
    rdfs:comment "Describes the brain region or cognitive area associated with an archetype."@en ;
    rdfs:range xsd:string .

ns4:archetypeChemicalMessenger a owl:DatatypeProperty ;
    rdfs:comment "Describes the neurotransmitter or chemical messenger linked to an archetype."@en ;
    rdfs:range xsd:string .

ns4:archetypeLikes a owl:DatatypeProperty ;
    rdfs:comment "Describes what an archetype prefers, values, or is drawn to."@en ;
    rdfs:range xsd:string .

ns4:autonomy a ns4:Motivation,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to self-determination, choice, and control."@en .

ns4:business a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context where gamification applies to commercial or corporate settings."@en .

ns4:classifiesPlayer a owl:ObjectProperty ;
    rdfs:comment "Indicates that a player is assigned to a particular player model or type."@en ;
    rdfs:domain ns4:Player_Model ;
    rdfs:range ns4:Player ;
    owl:inverseOf ns4:isClassifiedBy .

ns4:composesDynamic a owl:ObjectProperty ;
    rdfs:comment "Connects a game mechanic to the higher-level dynamic it composes."@en ;
    rdfs:domain ns4:GDE_Mechanic ;
    rdfs:range ns4:GDE_Dynamic .

ns4:computer-supported_cooperative_work a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context involving collaborative computer-mediated work."@en .

ns4:computer_science_and_engineering a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to STEM fields and engineering education."@en .

ns4:crowdsourcing a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context where tasks are distributed to a broad crowd of participants."@en .

ns4:describesPlayer a owl:ObjectProperty ;
    rdfs:comment "Associates a player with descriptive characteristics or metadata."@en ;
    rdfs:domain ns4:Player_Type ;
    rdfs:range ns4:Player ;
    owl:inverseOf ns4:isDescribedByType .

ns4:education a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to teaching and learning scenarios."@en .

ns4:facilitators a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context representing support actors or enabling services."@en .

ns4:financial a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to economic incentives or monetary systems."@en .

ns4:food a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to nutrition, meals, or food services."@en .

ns4:hasGamification a owl:ObjectProperty ;
    rdfs:comment "Indicates that a non-game context includes gamification elements."@en ;
    rdfs:domain ns4:Non-Game_Context ;
    rdfs:range ns4:Gamification ;
    owl:inverseOf ns4:isAppliedTo .

ns4:hasPlayerInteraction a owl:ObjectProperty ;
    rdfs:comment "Indicates that a gamification context provides a place for a player to interact."@en ;
    rdfs:domain ns4:Gamification_Context ;
    rdfs:range ns4:Player ;
    owl:inverseOf ns4:interactsIn .

ns4:health-care a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to health, medicine, and wellness."@en .

ns4:isComprisedOf a owl:ObjectProperty ;
    rdfs:comment "Indicates that a motivation or model is composed of smaller components."@en ;
    rdfs:domain ns4:Motivation ;
    rdfs:range ns4:Motivational_Component .

ns4:isUsedBy a owl:ObjectProperty ;
    rdfs:comment "Identifies the higher-level element that uses the given game element."@en ;
    rdfs:domain ns4:Game_Design_Element,
        ns4:Motivation_And_Need_Theory ;
    rdfs:range ns4:Gamification ;
    owl:inverseOf ns4:makesUseOf .

ns4:marketing a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to customer engagement and promotion."@en .

ns4:mastery a ns4:Motivation,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to competence and skill growth."@en .

ns4:orientation a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to onboarding and introductory processes."@en .

ns4:personal a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to individual or personal use cases."@en .

ns4:power a ns4:Motivation,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to influence, control, and leadership."@en .

ns4:purpose a ns4:Motivation,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to meaningful goals and contribution."@en .

ns4:research a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to scientific inquiry and studies."@en .

ns4:signal a ns4:Motivation,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to recognition, reputation, and communication."@en .

ns4:social_networks a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to social media and online communities."@en .

ns4:spark a ns4:Motivation,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to intrinsic interest and curiosity."@en .

ns4:sustainability a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to environmental sustainability and long-term impact."@en .

ns4:water a ns4:Non-Game_Context,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to water resources and environmental water management."@en .

ns1:SDT_Autonomy a owl:Class ;
    rdfs:comment "Autonomy is the need to have independence and to be able make own choices."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Self-Determination_Theory [ a owl:Restriction ;
                        owl:onProperty ns1:isSatisfiedWith ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Narrative ns4:Progression ) ] ] ) ] .

ns1:SDT_Competence a owl:Class ;
    rdfs:comment "Competence is the need to control the outcomes and experience a sense of ability (mastery)"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Self-Determination_Theory [ a owl:Restriction ;
                        owl:onProperty ns1:isSatisfiedWith ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Constraints ns4:Progression ) ] ] ) ] .

ns1:SDT_Relatedness a owl:Class ;
    rdfs:comment "Relatedness is the need to be connected with others, iterate with them, and experience caring for them."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Self-Determination_Theory [ a owl:Restriction ;
                        owl:onProperty ns1:isSatisfiedWith ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Emotions ns4:Relationships ) ] ] ) ] .

ns1:Yee_Advancement a owl:Class ;
    rdfs:comment "Players who derive satisfaction from reaching goals, leveling quickly and accumulating in-game resources such as gold."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Achievement_Component [ a owl:Restriction ;
                        owl:onProperty ns1:isMotivatedWith ;
                        owl:someValuesFrom ns4:Progression ] ) ] .

ns1:Yee_Competition a owl:Class ;
    rdfs:comment "Players who enjoy competing with other gamers on the battlefield or economy."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Achievement_Component [ a owl:Restriction ;
                        owl:onProperty ns1:isMotivatedWith ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Emotions ns4:Relationships ) ] ] ) ] .

ns1:Yee_Customization a owl:Class ;
    rdfs:comment "Players who enjoy customizing the appearance of their characters."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Immersion_Component [ a owl:Restriction ;
                        owl:onProperty ns1:isMotivatedWith ;
                        owl:someValuesFrom ns4:Narrative ] ) ] .

ns1:Yee_Discovery a owl:Class ;
    rdfs:comment "Players who enjoy exploring the world and discovering locations, quests or artifacts that others may not know about."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Immersion_Component [ a owl:Restriction ;
                        owl:onProperty ns1:isMotivatedWith ;
                        owl:someValuesFrom ns4:Progression ] ) ] .

ns1:Yee_Escapism a owl:Class ;
    rdfs:comment "Players who use the environment as a place to relax or relieve their stress from the real world."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Immersion_Component [ a owl:Restriction ;
                        owl:onProperty ns1:isMotivatedWith ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Emotions ns4:Narrative ) ] ] ) ] .

ns1:Yee_Mechanics a owl:Class ;
    rdfs:comment "Players who derive satisfaction from analyzing and understanding the underlying numerical mechanics of the system."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Achievement_Component [ a owl:Restriction ;
                        owl:onProperty ns1:isMotivatedWith ;
                        owl:someValuesFrom ns4:Constraints ] ) ] .

ns1:Yee_Relationship a owl:Class ;
    rdfs:comment "Players who are looking to form sustained, meaningful relationships with others."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Social_Component [ a owl:Class ;
                        owl:intersectionOf ( [ a owl:Restriction ;
                                    owl:onProperty ns1:isMotivatedWith ;
                                    owl:someValuesFrom ns4:Emotions ] [ a owl:Restriction ;
                                    owl:onProperty ns1:isMotivatedWith ;
                                    owl:someValuesFrom ns4:Relationships ] ) ] ) ] .

ns1:Yee_Role-Playing a owl:Class ;
    rdfs:comment "Players who enjoy being immersed in a story through the eyes of a character that they designed."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Immersion_Component [ a owl:Restriction ;
                        owl:onProperty ns1:isMotivatedWith ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( ns4:Constraints ns4:Narrative ) ] ] ) ] .

ns1:Yee_Socializing a owl:Class ;
    rdfs:comment "Players who enjoy meeting and getting to know other gamers"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Social_Component [ a owl:Restriction ;
                        owl:onProperty ns1:isMotivatedWith ;
                        owl:someValuesFrom ns4:Relationships ] ) ] .

ns1:Yee_Teamwork a owl:Class ;
    rdfs:comment "Players who enjoy working and collaborating with others"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( ns1:Yee_Social_Component [ a owl:Class ;
                        owl:intersectionOf ( [ a owl:Restriction ;
                                    owl:onProperty ns1:isMotivatedWith ;
                                    owl:someValuesFrom ns4:Progression ] [ a owl:Restriction ;
                                    owl:onProperty ns1:isMotivatedWith ;
                                    owl:someValuesFrom ns4:Relationships ] ) ] ) ] .

ns1:competionName a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for competitive behavior metrics."@en ;
    rdfs:domain ns1:CategoryCompetition ;
    rdfs:range xsd:string .

ns1:effectiveness a owl:NamedIndividual ;
    rdfs:comment "An example instance of effectiveness measurement in a gamified system."@en .

ns1:effectivenessName a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for effectiveness measurement."@en ;
    rdfs:domain ns1:CategoryEffectiveness ;
    rdfs:range xsd:string .

ns1:engagement a owl:NamedIndividual ;
    rdfs:comment "An example instance of an engagement metric or engagement state."@en .

ns1:enjoyment a owl:NamedIndividual ;
    rdfs:comment "An example instance of enjoyment measurement."@en .

ns1:enjoymentName a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for enjoyment metrics."@en ;
    rdfs:domain ns1:CategoryEnjoyment ;
    rdfs:range xsd:string .

ns1:explorationName a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for exploration behavior tracking."@en ;
    rdfs:domain ns1:CategoryExploration ;
    rdfs:range xsd:string .

ns1:hasActivityLoops a owl:ObjectProperty ;
    rdfs:comment "Associates a gamification model with the activity loops it contains."@en ;
    rdfs:domain ns1:GamificationModel ;
    rdfs:range ns1:Activity_Loop .

ns1:hasCategory a owl:ObjectProperty ;
    rdfs:comment "Associates a target behavior with its category classification."@en ;
    rdfs:domain ns1:Target_Behavior ;
    rdfs:range ns1:Target_Behavior_Category .

ns1:hasGameElement a owl:ObjectProperty ;
    rdfs:comment "Specifies the game elements used in a design practice."@en ;
    rdfs:domain ns1:DesignPractice ;
    rdfs:range ns4:GDE_Component,
        ns4:GDE_Mechanic .

ns1:hasMetric a owl:ObjectProperty ;
    rdfs:comment "Associates a target behavior with the metrics that measure it."@en ;
    rdfs:domain ns1:Target_Behavior ;
    rdfs:range ns1:Metric ;
    owl:inverseOf ns1:isUsedFor .

ns1:hasPlayer a owl:ObjectProperty ;
    rdfs:comment "Associates a player action with the player performing it."@en ;
    rdfs:domain ns1:Player_Action ;
    rdfs:range ns4:Player .

ns1:hasTargetBehavior a owl:ObjectProperty ;
    rdfs:comment "Specifies the intended behavior that a design practice aims to achieve."@en ;
    rdfs:domain ns1:DesignPractice ;
    rdfs:range ns1:Target_Behavior .

ns1:increaseHappiness a owl:NamedIndividual ;
    rdfs:comment "An example target behavior aimed at increasing player happiness or satisfaction."@en .

ns1:increasePerformance a owl:NamedIndividual ;
    rdfs:comment "An example target behavior aimed at improving player performance."@en .

ns1:interactionWithTheSystem a owl:NamedIndividual ;
    rdfs:comment "An example target behavior focused on increasing system interaction frequency or depth."@en .

ns1:isAccomplishedWith a owl:ObjectProperty ;
    rdfs:comment "Indicates the activity loop that accomplishes a target behavior."@en ;
    rdfs:domain ns1:Target_Behavior ;
    rdfs:range ns1:Activity_Loop ;
    owl:inverseOf ns1:leadsTo .

ns1:isComposedBy a owl:ObjectProperty ;
    rdfs:comment "Indicates the components (feedback, affordances, actions) that compose an engagement loop."@en ;
    rdfs:domain ns1:Engagement_Loop ;
    rdfs:range ns4:Feedback,
        ns1:Motivational_Affordance,
        ns1:Player_Action ;
    owl:inverseOf ns1:isPartOfEngagementLoop .

ns1:leadsToCompetition a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to competitive behavior."@en ;
    rdfs:domain ns4:Leaderboards ;
    rdfs:range ns1:CategoryCompetition .

ns1:leadsToEffectiveness a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to improved effectiveness or performance quality."@en ;
    rdfs:domain ns4:Badges,
        ns4:Leaderboards ;
    rdfs:range ns1:CategoryEffectiveness .

ns1:leadsToEnjoyment a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to increased enjoyment or satisfaction."@en ;
    rdfs:domain ns4:Achievements,
        ns4:Avatars,
        ns4:Badges,
        ns4:Points,
        ns4:Quests,
        ns4:Rewards,
        ns4:Story,
        ns4:Theme ;
    rdfs:range ns1:CategoryEnjoyment .

ns1:leadsToExploration a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element encourages exploration and discovery."@en ;
    rdfs:domain ns4:Achievements,
        ns4:Boss_Fights,
        ns4:Challenges,
        ns4:Levels ;
    rdfs:range ns1:CategoryExploration .

ns1:leadsToParticipation a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to increased participation and engagement."@en ;
    rdfs:domain ns4:Badges,
        ns4:Challenges,
        ns4:Leaderboards,
        ns4:Levels,
        ns4:Points,
        ns4:Rewards,
        ns4:Story,
        ns4:Theme ;
    rdfs:range ns1:CategoryParticipation .

ns1:leadsToPerformance a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to improved player performance."@en ;
    rdfs:domain ns4:Achievements,
        ns4:Badges,
        ns4:Challenges,
        ns4:Feedback,
        ns4:Leaderboards,
        ns4:Levels,
        ns4:Rewards,
        ns4:Story,
        ns4:Theme ;
    rdfs:range ns1:CategoryPerformance .

ns1:loopDifficulty a owl:DatatypeProperty ;
    rdfs:comment "A property indicating the difficulty level of an activity loop."@en ;
    rdfs:domain ns1:Progressive_Loop ;
    rdfs:range [ a rdfs:Datatype ;
            owl:onDatatype xsd:float ;
            owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:float ] [ xsd:maxInclusive "1.0"^^xsd:float ] ) ] .

ns1:loopQuality a owl:DatatypeProperty ;
    rdfs:comment "A property indicating the quality or design elegance of an activity loop."@en ;
    rdfs:domain ns1:Engagement_Loop ;
    rdfs:range [ a rdfs:Datatype ;
            owl:onDatatype xsd:float ;
            owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:float ] [ xsd:maxInclusive "1.0"^^xsd:float ] ) ] .

ns1:loopStatus a owl:DatatypeProperty ;
    rdfs:comment "A property indicating the state or status of an activity loop."@en ;
    rdfs:domain ns1:Engagement_Loop ;
    rdfs:range xsd:boolean .

ns1:metricDescription a owl:DatatypeProperty ;
    rdfs:comment "A string description of what a metric measures."@en ;
    rdfs:domain ns1:Metric ;
    rdfs:range xsd:string .

ns1:metricExpectedValue a owl:DatatypeProperty ;
    rdfs:comment "The expected or target value for a metric."@en ;
    rdfs:domain ns1:Metric ;
    rdfs:range xsd:double .

ns1:metricValue a owl:DatatypeProperty ;
    rdfs:comment "The actual measured or current value of a metric."@en ;
    rdfs:domain ns1:Metric ;
    rdfs:range xsd:double .

ns1:motivation a owl:NamedIndividual ;
    rdfs:comment "An example instance or measurement of player motivation."@en .

ns1:participation a owl:NamedIndividual ;
    rdfs:comment "An example instance of participation measurement or participation level."@en .

ns1:participationName a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for participation metrics."@en ;
    rdfs:domain ns1:CategoryParticipation ;
    rdfs:range xsd:string .

ns1:performance a owl:NamedIndividual ;
    rdfs:comment "An example instance of performance measurement."@en .

ns1:performanceName a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for performance metrics."@en ;
    rdfs:domain ns1:CategoryPerformance ;
    rdfs:range xsd:string .

ns1:satisfaction a owl:NamedIndividual ;
    rdfs:comment "An example instance of player satisfaction measurement."@en .

ns1:signupForTheSystem a owl:NamedIndividual ;
    rdfs:comment "An example target behavior aimed at increasing system signup or user registration."@en .

ns1:testEngagementLoop a ns1:Engagement_Loop,
        owl:NamedIndividual ;
    rdfs:comment "An example instance of an engagement loop for testing or demonstration purposes."@en .

ns2:hasBehaviouralKnowledge a owl:ObjectProperty ;
