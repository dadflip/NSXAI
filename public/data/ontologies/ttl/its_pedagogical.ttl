    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Sequencing> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Sequencing> a owl:Class ;
    rdfs:comment "A Sequencing is a map that represents the intended use of the content through structured units of instruction (curriculum)."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGInstrutionalPlan> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGInstrutionalPlan> a owl:Class ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGPedagogicalModel> .

<http://surveys.nees.com.br/ontologies/its_domain.owl#Course> a owl:Class ;
    rdfs:comment """
      An ITS Course bundles a set of knowledge Domains and is delivered to enrolled students.
    """@en .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug> a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge> ],
        <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception> a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge> ;
            owl:someValuesFrom <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge> ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge> ],
        <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasLO> a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge> <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit> ) ] ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Comment> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> .

