<http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Competence> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#THINGDomain> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#THINGDomain> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#DomainModel> .

