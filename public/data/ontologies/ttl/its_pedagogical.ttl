        owl:TransitiveProperty ;
    rdfs:domain <http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum> ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum> ;
    owl:inverseOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isChildOfCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#UniversalGenericOperator> a owl:Class ;
