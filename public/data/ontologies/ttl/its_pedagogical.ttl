<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#CurriculumUnit> a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#next_Curriculum> ],
        <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGInstrutionalPlan> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#InstrutionalPlan> a owl:Class ;
    rdfs:comment "Instructional Plan Strategy."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#PedagogicalModel> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#PedagogicalModel> a owl:Class ;
    rdfs:comment "Answer the question: How to teach? in a educational system."@en .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#ProblemNext> a owl:Class ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGInstrutionalPlan> .

