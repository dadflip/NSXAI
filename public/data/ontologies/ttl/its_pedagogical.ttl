<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#typeStrategyTutoring> a owl:DatatypeProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Strategy> ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#typeTactic> a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Tactic> ;
