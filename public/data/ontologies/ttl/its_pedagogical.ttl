<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Diagnosis> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Exercise> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnProblem> a owl:Class ;
