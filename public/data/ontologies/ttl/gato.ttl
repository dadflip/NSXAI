    rdfs:domain <http://surveys.nees.com.br/ontologies/gato.owl#GamifiedITS> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#GamificationModel> .

<http://surveys.nees.com.br/ontologies/gato.owl#hasPedagogicalModel> a owl:ObjectProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gato.owl#GamifiedITS> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGInstrutionalPlan> .

<http://surveys.nees.com.br/ontologies/gato.owl#hasStudentModel> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gato.owl#GamifiedITS> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gato.owl#StudentModel> .

<http://surveys.nees.com.br/ontologies/gato.owl#includes> a owl:ObjectProperty ;
