    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryParticipation> ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_full.owl#performance> a owl:NamedIndividual ;
    rdfs:comment "An example instance of performance measurement."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#performanceName> a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for performance metrics."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryPerformance> ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_full.owl#satisfaction> a owl:NamedIndividual ;
    rdfs:comment "An example instance of player satisfaction measurement."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#signupForTheSystem> a owl:NamedIndividual ;
    rdfs:comment "An example target behavior aimed at increasing system signup or user registration."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#testEngagementLoop> a <http://surveys.nees.com.br/ontologies/gado_full.owl#Engagement_Loop>,
        owl:NamedIndividual ;
    rdfs:comment "An example instance of an engagement loop for testing or demonstration purposes."@en .

<http://surveys.nees.com.br/ontologies/gato.owl> a owl:Ontology ;
    rdfs:label "GATO - Gamified ITS Ontology"@en ;
    rdfs:comment """
            GATO integrates GADO Full (gamification) with the ITS Pedagogical ontology
            to model a complete Gamified Intelligent Tutoring System.
            Defines GamifiedITS and StudentModel, and reuses GamificationModel from GADO Full.
        """@en ;
    owl:imports <http://surveys.nees.com.br/ontologies/gado_full.owl>,
        <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl> ;
    owl:versionIRI <http://surveys.nees.com.br/ontologies/gato.owl/1.0> ;
    owl:versionInfo "1.0-fixed"^^xsd:string .

<http://surveys.nees.com.br/ontologies/gato.owl#hasBehaviouralKnowledge> a owl:ObjectProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gato.owl#StudentModel> ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge> .

<http://surveys.nees.com.br/ontologies/gato.owl#hasDomainModel> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gato.owl#GamifiedITS> ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#DomainModel> .

<http://surveys.nees.com.br/ontologies/gato.owl#hasGamificationModel> a owl:FunctionalProperty,
