<http://rdfs.org/sioc/ns#UserAccount> a owl:Class ;
    rdfs:comment "A user account (student or instructor) in the ITS platform (from SIOC vocabulary)."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Context> a owl:Class ;
    rdfs:comment "A broader context or environment where a game or gamified experience takes place."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification_Context> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#affordsMotivation> a owl:ObjectProperty ;
    rdfs:comment "Relates a game design element or mechanic to the type of motivation it supports."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#archetypeBehavior> a owl:DatatypeProperty ;
    rdfs:comment "Describes the typical behavior associated with a player archetype."@en ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_core.owl#archetypeBrainRegion> a owl:DatatypeProperty ;
    rdfs:comment "Describes the brain region or cognitive area associated with an archetype."@en ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_core.owl#archetypeChemicalMessenger> a owl:DatatypeProperty ;
    rdfs:comment "Describes the neurotransmitter or chemical messenger linked to an archetype."@en ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_core.owl#archetypeLikes> a owl:DatatypeProperty ;
    rdfs:comment "Describes what an archetype prefers, values, or is drawn to."@en ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_core.owl#autonomy> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation>,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to self-determination, choice, and control."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#business> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context where gamification applies to commercial or corporate settings."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#classifiesPlayer> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a player is assigned to a particular player model or type."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Model> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Player> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_core.owl#isClassifiedBy> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#composesDynamic> a owl:ObjectProperty ;
    rdfs:comment "Connects a game mechanic to the higher-level dynamic it composes."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Dynamic> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#computer-supported_cooperative_work> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context involving collaborative computer-mediated work."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#computer_science_and_engineering> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to STEM fields and engineering education."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#crowdsourcing> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context where tasks are distributed to a broad crowd of participants."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#describesPlayer> a owl:ObjectProperty ;
    rdfs:comment "Associates a player with descriptive characteristics or metadata."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Player> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_core.owl#isDescribedByType> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#education> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to teaching and learning scenarios."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#facilitators> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context representing support actors or enabling services."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#financial> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to economic incentives or monetary systems."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#food> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to nutrition, meals, or food services."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#hasGamification> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a non-game context includes gamification elements."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_core.owl#isAppliedTo> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#hasPlayerInteraction> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a gamification context provides a place for a player to interact."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification_Context> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Player> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_core.owl#interactsIn> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#health-care> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to health, medicine, and wellness."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#isComprisedOf> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a motivation or model is composed of smaller components."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivational_Component> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#isUsedBy> a owl:ObjectProperty ;
    rdfs:comment "Identifies the higher-level element that uses the given game element."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation_And_Need_Theory> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_core.owl#makesUseOf> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#marketing> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to customer engagement and promotion."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#mastery> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation>,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to competence and skill growth."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#orientation> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to onboarding and introductory processes."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#personal> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to individual or personal use cases."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#power> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation>,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to influence, control, and leadership."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#purpose> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation>,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to meaningful goals and contribution."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#research> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to scientific inquiry and studies."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#signal> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation>,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to recognition, reputation, and communication."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#social_networks> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to social media and online communities."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#spark> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation>,
        owl:NamedIndividual ;
    rdfs:comment "A motivational construct related to intrinsic interest and curiosity."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#sustainability> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to environmental sustainability and long-term impact."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#water> a <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context>,
        owl:NamedIndividual ;
    rdfs:comment "A non-game context related to water resources and environmental water management."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Achiever> a owl:Class ;
    rdfs:comment "This archetype is more explicitly goal-oriented, motivated by long-term achievements."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#coversComponent> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#BrainHex> a owl:Class ;
    rdfs:comment "Typology of playing preferences motivated by combining existing findings from player research with neurobiological insights into the presumed underlying mechanisms"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Model> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#describesType> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Conqueror> a owl:Class ;
    rdfs:comment "Players fitting the this archetype enjoy defeating impossibly difficult foes, struggling until they achieve victory, and beating other players."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#coversComponent> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Daredevil> a owl:Class ;
    rdfs:comment "This play style is all about the thrill of the chase, the excitement of risk taking and generally playing on the edge."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#coversComponent> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Mastermind> a owl:Class ;
    rdfs:comment "Players who fit this archetype enjoy solving puzzles and devising strategies, as well as focusing on making the most efficient decisions."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#coversComponent> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#SDT_Autonomy> a owl:Class ;
    rdfs:comment "Autonomy is the need to have independence and to be able make own choices."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Self-Determination_Theory> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isSatisfiedWith> ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ) ] ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#SDT_Competence> a owl:Class ;
    rdfs:comment "Competence is the need to control the outcomes and experience a sense of ability (mastery)"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Self-Determination_Theory> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isSatisfiedWith> ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ) ] ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#SDT_Relatedness> a owl:Class ;
    rdfs:comment "Relatedness is the need to be connected with others, iterate with them, and experience caring for them."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Self-Determination_Theory> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isSatisfiedWith> ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ) ] ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Seeker> a owl:Class ;
    rdfs:comment "Motivated by interest mechanism, which relates to the brain area processing sensory information and memory association."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> <http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#coversComponent> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Socializer> a owl:Class ;
    rdfs:comment "People are a primary source of enjoyment for players fitting this archetype"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#coversComponent> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Survivor> a owl:Class ;
    rdfs:comment "This archetype could be related to Lazzaro's serious fun, but in either case it can be seen as a special case of Caillois' ilinx, which purposefully courts controlled experiences of panic"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> <http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#coversComponent> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Advancement> a owl:Class ;
    rdfs:comment "Players who derive satisfaction from reaching goals, leveling quickly and accumulating in-game resources such as gold."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Achievement_Component> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                        owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Competition> a owl:Class ;
    rdfs:comment "Players who enjoy competing with other gamers on the battlefield or economy."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Achievement_Component> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ) ] ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Customization> a owl:Class ;
    rdfs:comment "Players who enjoy customizing the appearance of their characters."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Immersion_Component> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                        owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Discovery> a owl:Class ;
    rdfs:comment "Players who enjoy exploring the world and discovering locations, quests or artifacts that others may not know about."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Immersion_Component> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                        owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Escapism> a owl:Class ;
    rdfs:comment "Players who use the environment as a place to relax or relieve their stress from the real world."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Immersion_Component> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> <http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> ) ] ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Mechanics> a owl:Class ;
    rdfs:comment "Players who derive satisfaction from analyzing and understanding the underlying numerical mechanics of the system."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Achievement_Component> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                        owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Relationship> a owl:Class ;
    rdfs:comment "Players who are looking to form sustained, meaningful relationships with others."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Social_Component> [ a owl:Class ;
                        owl:intersectionOf ( [ a owl:Restriction ;
                                    owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                                    owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> ] [ a owl:Restriction ;
                                    owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                                    owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ] ) ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Role-Playing> a owl:Class ;
    rdfs:comment "Players who enjoy being immersed in a story through the eyes of a character that they designed."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Immersion_Component> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                        owl:someValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> <http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> ) ] ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Socializing> a owl:Class ;
    rdfs:comment "Players who enjoy meeting and getting to know other gamers"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Social_Component> [ a owl:Restriction ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                        owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Teamwork> a owl:Class ;
    rdfs:comment "Players who enjoy working and collaborating with others"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Social_Component> [ a owl:Class ;
                        owl:intersectionOf ( [ a owl:Restriction ;
                                    owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                                    owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ] [ a owl:Restriction ;
                                    owl:onProperty <http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> ;
                                    owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ] ) ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#competionName> a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for competitive behavior metrics."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryCompetition> ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_full.owl#effectiveness> a owl:NamedIndividual ;
    rdfs:comment "An example instance of effectiveness measurement in a gamified system."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#effectivenessName> a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for effectiveness measurement."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryEffectiveness> ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_full.owl#engagement> a owl:NamedIndividual ;
    rdfs:comment "An example instance of an engagement metric or engagement state."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#enjoyment> a owl:NamedIndividual ;
    rdfs:comment "An example instance of enjoyment measurement."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#enjoymentName> a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for enjoyment metrics."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryEnjoyment> ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_full.owl#explorationName> a owl:DatatypeProperty ;
    rdfs:comment "A string name or label for exploration behavior tracking."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryExploration> ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_full.owl#hasActivityLoops> a owl:ObjectProperty ;
    rdfs:comment "Associates a gamification model with the activity loops it contains."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#GamificationModel> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#Activity_Loop> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#hasCategory> a owl:ObjectProperty ;
    rdfs:comment "Associates a target behavior with its category classification."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior_Category> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#hasGameElement> a owl:ObjectProperty ;
    rdfs:comment "Specifies the game elements used in a design practice."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#DesignPractice> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#hasMetric> a owl:ObjectProperty ;
    rdfs:comment "Associates a target behavior with the metrics that measure it."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#Metric> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_full.owl#isUsedFor> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#hasPlayer> a owl:ObjectProperty ;
    rdfs:comment "Associates a player action with the player performing it."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Player_Action> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Player> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#hasTargetBehavior> a owl:ObjectProperty ;
    rdfs:comment "Specifies the intended behavior that a design practice aims to achieve."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#DesignPractice> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#increaseHappiness> a owl:NamedIndividual ;
    rdfs:comment "An example target behavior aimed at increasing player happiness or satisfaction."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#increasePerformance> a owl:NamedIndividual ;
    rdfs:comment "An example target behavior aimed at improving player performance."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#interactionWithTheSystem> a owl:NamedIndividual ;
    rdfs:comment "An example target behavior focused on increasing system interaction frequency or depth."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#isAccomplishedWith> a owl:ObjectProperty ;
    rdfs:comment "Indicates the activity loop that accomplishes a target behavior."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#Activity_Loop> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_full.owl#leadsTo> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#isComposedBy> a owl:ObjectProperty ;
    rdfs:comment "Indicates the components (feedback, affordances, actions) that compose an engagement loop."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Engagement_Loop> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Feedback>,
        <http://surveys.nees.com.br/ontologies/gado_full.owl#Motivational_Affordance>,
        <http://surveys.nees.com.br/ontologies/gado_full.owl#Player_Action> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_full.owl#isPartOfEngagementLoop> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#leadsToCompetition> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to competitive behavior."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Leaderboards> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryCompetition> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#leadsToEffectiveness> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to improved effectiveness or performance quality."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Badges>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Leaderboards> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryEffectiveness> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#leadsToEnjoyment> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to increased enjoyment or satisfaction."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Achievements>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Avatars>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Badges>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Points>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Quests>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Rewards>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Story>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Theme> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryEnjoyment> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#leadsToExploration> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element encourages exploration and discovery."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Achievements>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Boss_Fights>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Levels> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryExploration> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#leadsToParticipation> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to increased participation and engagement."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Badges>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Leaderboards>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Levels>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Points>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Rewards>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Story>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Theme> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryParticipation> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#leadsToPerformance> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a game element leads to improved player performance."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Achievements>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Badges>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Feedback>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Leaderboards>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Levels>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Rewards>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Story>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Theme> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryPerformance> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#loopDifficulty> a owl:DatatypeProperty ;
    rdfs:comment "A property indicating the difficulty level of an activity loop."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Progressive_Loop> ;
    rdfs:range [ a rdfs:Datatype ;
            owl:onDatatype xsd:float ;
            owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:float ] [ xsd:maxInclusive "1.0"^^xsd:float ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#loopQuality> a owl:DatatypeProperty ;
    rdfs:comment "A property indicating the quality or design elegance of an activity loop."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Engagement_Loop> ;
    rdfs:range [ a rdfs:Datatype ;
            owl:onDatatype xsd:float ;
            owl:withRestrictions ( [ xsd:minInclusive "0.0"^^xsd:float ] [ xsd:maxInclusive "1.0"^^xsd:float ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#loopStatus> a owl:DatatypeProperty ;
    rdfs:comment "A property indicating the state or status of an activity loop."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Engagement_Loop> ;
    rdfs:range xsd:boolean .

<http://surveys.nees.com.br/ontologies/gado_full.owl#metricDescription> a owl:DatatypeProperty ;
    rdfs:comment "A string description of what a metric measures."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Metric> ;
    rdfs:range xsd:string .

<http://surveys.nees.com.br/ontologies/gado_full.owl#metricExpectedValue> a owl:DatatypeProperty ;
    rdfs:comment "The expected or target value for a metric."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Metric> ;
    rdfs:range xsd:double .

<http://surveys.nees.com.br/ontologies/gado_full.owl#metricValue> a owl:DatatypeProperty ;
    rdfs:comment "The actual measured or current value of a metric."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Metric> ;
    rdfs:range xsd:double .

<http://surveys.nees.com.br/ontologies/gado_full.owl#motivation> a owl:NamedIndividual ;
    rdfs:comment "An example instance or measurement of player motivation."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#participation> a owl:NamedIndividual ;
    rdfs:comment "An example instance of participation measurement or participation level."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#participationName> a owl:DatatypeProperty ;
