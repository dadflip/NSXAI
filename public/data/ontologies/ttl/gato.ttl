<http://surveys.nees.com.br/ontologies/its_domain.owl#teachesDomain> a owl:ObjectProperty ;
    rdfs:comment "Specifies the knowledge Domain taught by a Course."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/its_domain.owl#Course> ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain> .

<mt:Competence> rdfs:comment "A competence groups several Domains that a student is expected to master."@en .

<mt:Domain> rdfs:comment """
      A knowledge Domain is the subject-matter area taught by an ITS.
      It is structured by at least one Context, Depth level, and Curriculum.
    """@en .

<mt:DomainModel> rdfs:comment "Answers the question \"What to teach?\" in an educational system."@en .

<mt:associatedDomain> rdfs:comment "Associates any resource with its knowledge domain."@en .

<mt:desiredPoints> rdfs:comment "Target score or point threshold for a student performance goal."@en .

<mt:domain> rdfs:comment "String label for the Domain (used alongside the IRI)."@en .

<mt:hasDomains> rdfs:comment "Links a Competence to the Domains it covers."@en .

<mt:hasEloRating> rdfs:comment "Elo rating associated with a domain entity (used for student modelling)."@en .

<mt:hasLevel> rdfs:comment "Proficiency level associated with a domain entity."@en .

<mt:hasSubDomain> rdfs:comment "Links a domain to one of its sub-domains."@en .

<mt:isComposedByContext> rdfs:comment "Relates a Domain to the Contexts from which it can be viewed."@en .

<mt:isComposedByCurriculum> rdfs:comment "Relates a Domain to its constituent Curriculum units."@en .

<mt:isComposedByDepth> rdfs:comment "Relates a Domain to the Depth levels used to stratify its knowledge."@en .

<mt:type> rdfs:comment "Classification type of the Domain (e.g. academic, professional, vocational)."@en .

<mtcp:Context> rdfs:comment """
      Represents a particular standpoint or interpretation of a knowledge domain.
      Different Contexts yield different representations of the same knowledge object.
    """@en .

<mtcp:Curriculum> rdfs:comment """
      A Curriculum node is a <Context, Depth> pair that groups a set of Pedagogical Units
      defined according to teaching/learning objectives.
    """@en .

<mtcp:Depth> rdfs:comment """
      Stratifies the epistemological levels of knowledge-object perception within a given Context.
    """@en .

<mtcp:hasContext> rdfs:comment "Associates an entity with its Context."@en .

<mtcp:importanceLevel> rdfs:comment "Relative importance of this Curriculum node within the domain."@en .

<mtcp:isChildOfCurriculum> rdfs:comment "Transitive child relationship between Curriculum nodes."@en .

<mtcp:isComposedByContext> rdfs:comment "A Curriculum is composed by exactly one Context."@en .

<mtcp:isComposedByDepth> rdfs:comment "A Curriculum is composed by exactly one Depth level."@en .

<mtcp:isComposedByLaterality> rdfs:comment """
      Relates a Curriculum to sibling Curricula that represent prerequisite knowledge
      from a particular Context/Depth perspective.
    """@en .

<mtcp:isParentOfCurriculum> rdfs:comment "Transitive parent relationship between Curriculum nodes."@en .

<mtcp:issue> rdfs:comment "Human-readable label / identifier for a Context, Curriculum or Depth node."@en .

<mtcp:type> rdfs:comment "Classification type of a Context (e.g. formal, informal, professional)."@en .

<mtcu:BehaviouralKnowledge> rdfs:comment """
      Encodes the domain-specific inference rules or procedures a student should be able to perform.
    """@en .

<mtcu:Bug> rdfs:comment "A systematic procedural error in the student's behavioural knowledge."@en .

<mtcu:Bug_Misconception> rdfs:comment "A catalogue entry that is simultaneously a Bug and a Misconception."@en .

<mtcu:CKCurriculumInformation> rdfs:comment "Metadata linking a ConceptualKnowledge node to its Curriculum position (cluster, precedence)."@en .

<mtcu:Catalogue> rdfs:comment "Abstract catalogue of known student difficulties (bugs, errors, misconceptions)."@en .

<mtcu:ConceptualKnowledge> rdfs:comment """
      Contains the definitions of concepts underlying the Behavioural Knowledge,
      i.e. the concepts involved in an inference mechanism.
    """@en .

<mtcu:Error> rdfs:comment "A specific incorrect response or calculation error."@en .

<mtcu:Error_Bug> rdfs:comment "A catalogue entry that is simultaneously a Bug and an Error."@en .

<mtcu:Error_Misconception> rdfs:comment "A catalogue entry that is simultaneously an Error and a Misconception."@en .

<mtcu:GenericOperator> rdfs:comment """
      Defines how the system knowledge (Rs*k) and the bug/misconception catalogues
      interact to create a diagnosis space.
    """@en .

<mtcu:KnowledgeUnit> rdfs:comment """
      Groups support knowledge for problem-solving: concepts, results, examples, counter-examples,
      hints, and analogous problems (from the same class).
    """@en .

<mtcu:Misconception> rdfs:comment "A faulty conceptual belief held by the student."@en .

<mtcu:PedagogicalUnit> rdfs:comment """
      A Pedagogical Unit (PU) corresponds to a set of problems and resources ordered
      according to pedagogical criteria.
    """@en .

<mtcu:ResourceWeight> rdfs:comment "Associates a resource with its relative weight within a pedagogical unit."@en .

<mtcu:UniversalGenericOperator> rdfs:comment """
      Represents any Behavioural Knowledge associated with all bugs in the bug catalogue.
    """@en .

<mtcu:ckType> rdfs:comment "Classifies the type of conceptual knowledge (e.g. declarative, procedural)."@en .

<mtcu:cluster> rdfs:comment "Cluster identifier grouping related ConceptualKnowledge nodes."@en .

<mtcu:difficulty> rdfs:comment """
      Represents how difficult the learning resource is for the typical target audience.
    """@en .

<mtcu:domain> rdfs:comment "String identifier of the knowledge domain (used when a full IRI reference is not available)."@en .

<mtcu:hasBehaviouralKnowledge> rdfs:comment "Associates a knowledge entity with its Behavioural Knowledge definition."@en .

<mtcu:hasCatalogue> rdfs:comment "Associates a knowledge entity with its bug/error/misconception Catalogue."@en .

<mtcu:hasConceptualKnowledge> rdfs:comment "Associates a knowledge entity with its Conceptual Knowledge definition."@en .

<mtcu:hasConsistency> rdfs:comment "Consistency indicator for a curriculum entity."@en .

<mtcu:hasDiscrepancy> rdfs:comment "Records a discrepancy detected by a Generic Operator."@en .

<mtcu:hasDomain> rdfs:comment "Links a ConceptualKnowledge node to its knowledge Domain."@en .

<mtcu:hasExplanation> rdfs:comment "Links a knowledge entity to an explanatory Learning Object."@en .

<mtcu:hasKnowledgeUnit> rdfs:comment "A Pedagogical Unit is associated with exactly one Knowledge Unit."@en .

<mtcu:hasLO> rdfs:comment "Super-property grouping all Learning Object associations."@en .

<mtcu:hasPG> rdfs:comment "BKT parameter: probability of a correct guess (P(G))."@en .

<mtcu:hasPL0> rdfs:comment "BKT parameter: initial probability of knowledge (P(L0))."@en .

<mtcu:hasPS> rdfs:comment "BKT parameter: probability of a slip / incorrect answer despite knowledge (P(S))."@en .

<mtcu:hasPT> rdfs:comment "BKT parameter: probability of learning / transition (P(T))."@en .

<mtcu:hasPedagogicalUnit> rdfs:comment "A Curriculum contains one or more Pedagogical Units."@en .

<mtcu:hasSuperConceptualKnowledge> rdfs:comment "Points to the parent ConceptualKnowledge in a generalisation hierarchy."@en .

<mtcu:hasTags> rdfs:comment "Free-text tags associated with a ConceptualKnowledge node."@en .

<mtcu:has_Curriculum> rdfs:comment "Functional shortcut linking any entity to its single Curriculum."@en .

<mtcu:has_MissConception> rdfs:comment "Links a Diagnosis to the ConceptualKnowledge node that represents the misconception."@en .

<mtcu:isComposedByLaterality> rdfs:comment """
      Relates a Knowledge Unit to prerequisite Curricula (lateral knowledge),
      i.e. supportive knowledge from a given Context/Depth perspective.
    """@en .

<mtcu:isComposedByProblem> rdfs:comment "Relates a catalogue entry to the problem that triggers it."@en .

<mtcu:issue> rdfs:comment "Human-readable label / identifier for a ConceptualKnowledge or PedagogicalUnit node."@en .

<mtcu:precedence> rdfs:comment "Ordering precedence of a knowledge node within its curriculum."@en .

<mtcu:rate> rdfs:comment "Frequency/probability rate of the bug, error, or misconception."@en .

<mtcu:weight> rdfs:comment "Relative weight of a resource within a pedagogical unit."@en .

<mtr:Activity> rdfs:comment "A student activity resource with defined start/end dates and weight."@en .

<mtr:Comment> rdfs:comment "A peer or instructor comment attached to a Problem."@en .

<mtr:CompositeResource> rdfs:comment "A resource composed of multiple atomic (non-composite) resources."@en .

<mtr:Concept> rdfs:comment "A definitional concept resource presented to the student."@en .

<mtr:Content> rdfs:comment "A content resource (e.g. lecture notes, video, reading material)."@en .

<mtr:Diagnosis> rdfs:comment "A diagnostic result triggered by a student selecting a particular Option."@en .

<mtr:DiscursiveProblem> rdfs:comment "A free-text / discursive problem requiring an open-ended written answer."@en .

<mtr:EvaluationResource> rdfs:comment "Abstract superclass for all evaluation types."@en .

<mtr:Exercise> rdfs:comment "A worked example or exercise resource."@en .

<mtr:Form> rdfs:comment "A form-based evaluation containing survey Questions."@en .

<mtr:Hint> rdfs:comment "A scaffolded hint provided to a student during problem-solving; hints form a tree."@en .

<mtr:MatchColumnAnswer> rdfs:comment "Identifies the correct matching answer(s) in a MatchColumnProblem."@en .

<mtr:MethodStep> rdfs:comment "An individual step within a ResolutionMethod."@en .

<mtr:Option> rdfs:comment "Abstract superclass for all answer options."@en .

<mtr:OptionAnswer> rdfs:comment "The correct answer value (\"true\" or \"false\") for a TrueOrFalseOption."@en .

<mtr:Problem> rdfs:comment "Abstract superclass for all problem types."@en .

<mtr:ProblemBasedEvaluation> rdfs:comment "An evaluation composed of a set of Problems."@en .

<mtr:Question> rdfs:comment "A survey or form question linked to a Curriculum."@en .

<mtr:Resolution> rdfs:comment "The worked solution associated with a Problem."@en .

<mtr:ResolutionMethod> rdfs:comment "A named resolution strategy applicable to a problem class."@en .

<mtr:ResourceList> rdfs:comment "Enumerates the atomic resources that compose a CompositeResource."@en .

<mtr:Statement> rdfs:comment "The problem or activity statement presented to the student."@en .

<mtr:URIResource> rdfs:comment "URI pointing to the actual content of a Resource."@en .

<mtr:URIType> rdfs:comment "MIME type or format descriptor of the resource URI."@en .

<mtr:WritingEvaluation> rdfs:comment "A free-text writing evaluation."@en .

<mtr:context> rdfs:comment "Contextual information or scenario description for a Problem."@en .

<mtr:corrected> rdfs:comment "Indicates whether the evaluation has been corrected / graded."@en .

<mtr:developmentStatus> rdfs:comment "Development status of the problem (e.g. draft, reviewed, published)."@en .

<mtr:difficulty> rdfs:comment "IRT difficulty parameter for a Problem."@en .

<mtr:duration> rdfs:comment "Estimated duration of the content resource in minutes."@en .

<mtr:enabled> rdfs:comment "Indicates whether a resource is currently available to students."@en .

<mtr:error> rdfs:comment "Description of the diagnosed error."@en .

<mtr:hasCalculations> rdfs:comment "Indicates whether the problem involves numerical calculations."@en .

<mtr:hasOption> rdfs:comment "Generic option association; specialised by problem-type sub-properties."@en .

<mtr:has_Answers> rdfs:comment "Accepted answer(s) for a fill-in-the-blanks option (pipe-separated if multiple)."@en .

<mtr:has_Diagnosis> rdfs:comment "Links an Option to the Diagnosis it triggers when chosen."@en .

<mtr:has_Epoch> rdfs:comment "Training epoch number associated with a problem-based evaluation (used in adaptive systems)."@en .

<mtr:has_Knowledge> rdfs:comment "Knowledge component addressed by a form question."@en .

<mtr:has_token> rdfs:comment "Access token or identifier for a specific problem instance."@en .

<mtr:issue> rdfs:comment "Known issue or errata associated with a Content resource."@en .

<mtr:item> rdfs:comment "The text content of an option presented to the student."@en .

<mtr:level> rdfs:comment "Proficiency level required for an activity or problem."@en .

<mtr:matched_To> rdfs:comment "Links a left-column option to its corresponding right-column match."@en .

<mtr:multipleChoiceAnswer> rdfs:comment "Identifies the correct option(s) in a MultipleChoiceProblem."@en .

<mtr:order> rdfs:comment "Display order of a hint or option within its problem."@en .

<mtr:size> rdfs:comment "Number of problems included in an evaluation."@en .

<mtr:subjects> rdfs:comment """
      Identifies the subject(s) covered by a simple evaluation
      (e.g. a specific domain, a specific curriculum, or all domains).
    """@en .

<mtr:superKC> rdfs:comment "Identifier of the parent knowledge component in the resource hierarchy."@en .

<mtr:term> rdfs:comment "The canonical term label for a Concept resource."@en .

<mtr:tokenized_statement> rdfs:comment "Tokenised (NLP-processed) version of the problem statement."@en .

<mtr:type_Test> rdfs:comment """
      Identifies whether an evaluation is simple (linked to a specific Domain or Curriculum)
      or comprehensive (covering all domains).
    """@en .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isChildOfCurriculum> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain <http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum> ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum> ;
    owl:inverseOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isParentOfCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isParentOfCurriculum> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain <http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum> ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum> ;
    owl:inverseOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#isChildOfCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#UniversalGenericOperator> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#CompositeResource> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#DiscursiveOption> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#DiscursiveProblem> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#FillBlanksProblem> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Form> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#TrueOrFalseProblem> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#isChildOfHint> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint> ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint> ;
    owl:inverseOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#isParentOfHint> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#isParentOfHint> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint> ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint> ;
    owl:inverseOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#isChildOfHint> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Competence> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#THINGDomain> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#THINGDomain> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#DomainModel> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#isSubDomainOf> a owl:ObjectProperty ;
    rdfs:domain <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain> ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain> .

<http://surveys.nees.com.br/ontologies/gado_core.owl> a owl:Ontology ;
    rdfs:label "GADO Core Ontology"@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Chances> a owl:Class ;
    rdfs:comment "Elements of randomness"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Collections> a owl:Class ;
    rdfs:comment "Set of items or badges to accumulate"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Resource_Acquisition> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Combat> a owl:Class ;
    rdfs:comment "A defined battle, typically short-lived"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Competition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Turns> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Content_Unlocking> a owl:Class ;
    rdfs:comment "Aspects available only when players reach objectives"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Rewards> <http://surveys.nees.com.br/ontologies/gado_core.owl#Win_States> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Gifting> a owl:Class ;
    rdfs:comment "Opportunities to share resources with others"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Transactions> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Motivational_Component> a owl:Class ;
    rdfs:comment "A component of motivation that combines behavioral, affective, or cognitive drivers."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Social_Graph> a owl:Class ;
    rdfs:comment "The network of relationships among friends, such as the matrix of connections on Facebook or other social networking sites."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Cooperation> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Teams> a owl:Class ;
    rdfs:comment "Defined groups of players working together for a common goal"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Competition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Cooperation> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Time_Constraints> a owl:Class ;
    rdfs:comment "Restrictions on time that shape how players engage with the gamified experience."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges> <http://surveys.nees.com.br/ontologies/gado_core.owl#Competition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Win_States> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Virtual_Goods> a owl:Class ;
    rdfs:comment "Virtual items that have value or uniqueness within a game environment. Players may be able to purchase virtual goods with virtual currency, real money, or through achievements within the game. Also called virtual assets."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Resource_Acquisition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Transactions> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#describesType> a owl:ObjectProperty ;
    rdfs:comment "Links a type or model to the characteristics that describe it."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Model> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_core.owl#isDescribedByModel> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#interactsIn> a owl:ObjectProperty ;
    rdfs:comment "Specifies the gamification context in which a player interacts."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Player> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification_Context> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#isAppliedTo> a owl:ObjectProperty ;
    rdfs:comment "Identifies the object or context to which gamification is applied."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#isClassifiedBy> a owl:ObjectProperty ;
    rdfs:comment "Indicates the model or classifier used to categorize a player."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Player> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Model> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#isDescribedByModel> a owl:ObjectProperty ;
    rdfs:comment "Specifies the player model that describes a particular player type."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Model> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#isDescribedByType> a owl:ObjectProperty ;
    rdfs:comment "Specifies the player type that is used to describe a player."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Player> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#makesUseOf> a owl:ObjectProperty ;
    rdfs:comment "Indicates that one concept makes use of another for game behavior or motivation."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element>,
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation_And_Need_Theory> .

<http://surveys.nees.com.br/ontologies/gado_full.owl> a owl:Ontology ;
    rdfs:label "GADO Full Ontology"@en ;
    rdfs:comment "GADO Full extends GADO Core with player archetypes (Bartle, Yee), motivational affordances, activity loops, and design practices for gamification in educational ITS contexts."@en ;
    owl:imports <http://surveys.nees.com.br/ontologies/gado_core.owl> ;
    owl:versionInfo "1.1"^^xsd:string .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Progressive_Loop> a owl:Class ;
    rdfs:comment "Progression Loops (macro level; broader structures of activity throughout the course of the game)"@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Activity_Loop> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#isPartOfEngagementLoop> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a component belongs to an engagement loop."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Feedback> <http://surveys.nees.com.br/ontologies/gado_full.owl#Motivational_Affordance> <http://surveys.nees.com.br/ontologies/gado_full.owl#Player_Action> ) ] ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#Engagement_Loop> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#isUsedFor> a owl:ObjectProperty ;
    rdfs:comment "Indicates the target behavior that a metric is used to measure."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Metric> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#leadsTo> a owl:ObjectProperty ;
    rdfs:comment "Indicates the target behavior that an activity loop achieves."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Activity_Loop> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl> a owl:Ontology ;
    rdfs:label "ITS Pedagogical Ontology"@en ;
    rdfs:comment "Defines pedagogical models for Intelligent Tutoring Systems: instructional plans, sequencing strategies, tactics, and curriculum units."@en ;
    owl:imports <http://surveys.nees.com.br/ontologies/its_domain.owl> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGPedagogicalModel> a owl:Class .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#isChildOf_Strategy> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Strategy> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Strategy> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#isParentOf_Strategy> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#isChildOf_Tactic> a owl:ObjectProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Tactic> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Tactic> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#isParentOf_Tactic> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#isParentOf_Strategy> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Strategy> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Strategy> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#isChildOf_Strategy> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#isParentOf_Tactic> a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Tactic> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Tactic> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#isChildOf_Tactic> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#next_Curriculum> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#CurriculumUnit> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#CurriculumUnit> .

<http://surveys.nees.com.br/ontologies/its_domain.owl> a owl:Ontology ;
    rdfs:label "ITS Domain Ontology"@en ;
    rdfs:comment """
      Consolidated ITS domain ontology covering courses, knowledge domains, curriculum,
      pedagogical units, and learning resources. Derived from MeuTutor domain ontologies.
      The pedagogical layer (strategies, tactics, instructional plans) is defined separately
      in its.pedagogical.owl, which imports this ontology.
    """@en ;
    owl:versionInfo "1.1"^^xsd:string .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug_Misconception> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Bug> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error_Misconception> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#GenericOperator> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge> a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug> <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit> <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#UniversalGenericOperator> ) ] ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#BehaviouralKnowledge> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#FillBlanksOption> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceOption> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MultipleChoiceProblem> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#TrueOrFalseOption> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Avatars> a owl:Class ;
    rdfs:comment "A virtual representation of a player’s character in a game. Common in role-playing games in which the player might take on the role of a magical creature or a medieval warrior."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Feedback> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Boss_Fights> a owl:Class ;
    rdfs:comment "A difficult fight against a high-level opponent, called a boss. Often marks the end of a level or a section of a game"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Quests> a owl:Class ;
    rdfs:comment "A specific mission or challenge for players of a game. The quest will usually have a narrative and an objective and a reward for completion."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges> <http://surveys.nees.com.br/ontologies/gado_core.owl#Cooperation> <http://surveys.nees.com.br/ontologies/gado_core.owl#Rewards> <http://surveys.nees.com.br/ontologies/gado_core.owl#Story> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Status> a owl:Class ;
    rdfs:comment "The rank or level of a player. Players are often motivated by trying to reach a higher level or status. "@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Turns> a owl:Class ;
    rdfs:comment "Sequential participation by alternating players"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#tiesComponent> a owl:ObjectProperty ;
    rdfs:comment "Specifies that a mechanic connects to or supports a game component."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryCompetition> a owl:Class ;
    rdfs:comment "A target behavior category focused on competitive outcomes and achievement hierarchies."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior_Category> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryEffectiveness> a owl:Class ;
    rdfs:comment "A target behavior category measuring the efficiency and quality of player actions."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior_Category> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryEnjoyment> a owl:Class ;
    rdfs:comment "A target behavior category centered on player satisfaction and intrinsic motivation."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior_Category> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryExploration> a owl:Class ;
    rdfs:comment "A target behavior category focused on discovery, curiosity, and world engagement."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior_Category> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryParticipation> a owl:Class ;
    rdfs:comment "A target behavior category measuring engagement and involvement levels."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior_Category> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#CategoryPerformance> a owl:Class ;
    rdfs:comment "A target behavior category assessing player skill execution and mastery."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior_Category> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#DesignPractice> a owl:Class ;
    rdfs:comment "One or a set of game elements that leads a player to certain behaviors."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#GamificationModel> a owl:Class ;
    rdfs:comment "A complete model of gamification encompassing activity loops, engagement mechanics, and player affordances."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Motivational_Affordance> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#CKCurriculumInformation> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Error> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ResourceWeight> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge> a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit> <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception> ) ] ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Concept> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Diagnosis> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Exercise> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnProblem> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resolution> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#DomainModel> a owl:Class .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation_And_Need_Theory> a owl:Class ;
    rdfs:comment "A theory that links motivation, needs, and game design principles to explain player engagement."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Points> a owl:Class ;
    rdfs:comment "Numerical representations of game progression"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Competition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Resource_Acquisition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Rewards> <http://surveys.nees.com.br/ontologies/gado_core.owl#Win_States> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Transactions> a owl:Class ;
    rdfs:comment "Trading between players, directly or through intermediaries"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Achievement_Component> a owl:Class ;
    rdfs:comment "A motivational component from Yee's taxonomy focused on advancement and goal achievement."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Yees_Motivational_Components> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Social_Component> a owl:Class ;
    rdfs:comment "A motivational component from Yee's taxonomy focused on social interaction and relationships."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Yees_Motivational_Components> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#isSatisfiedWith> a owl:ObjectProperty ;
    rdfs:comment "Indicates the game element that satisfies a self-determination theory need."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Self-Determination_Theory> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element> .

<http://surveys.nees.com.br/ontologies/gato.owl#StudentModel> a owl:Class .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#CurriculumUnit> a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#next_Curriculum> ],
        <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGInstrutionalPlan> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#InstrutionalPlan> a owl:Class ;
    rdfs:comment "Instructional Plan Strategy."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#PedagogicalModel> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#PedagogicalModel> a owl:Class ;
    rdfs:comment "Answer the question: How to teach? in a educational system."@en .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#ProblemNext> a owl:Class ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGInstrutionalPlan> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#ProblemUnit> a owl:Class ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Sequencing> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Sequencing> a owl:Class ;
    rdfs:comment "A Sequencing is a map that represents the intended use of the content through structured units of instruction (curriculum)."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGInstrutionalPlan> .

<http://surveys.nees.com.br/ontologies/its_domain.owl#Course> a owl:Class ;
    rdfs:comment """
      An ITS Course bundles a set of knowledge Domains and is delivered to enrolled students.
    """@en .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Depth> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Bug> a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge> ],
        <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Misconception> a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge> ;
            owl:someValuesFrom <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge> ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge> ],
        <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#Catalogue> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasLO> a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge> <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit> ) ] ;
    rdfs:range <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Comment> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MethodStep> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Question> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ResolutionMethod> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Achievements> a owl:Class ;
    rdfs:comment "Defined objectives"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges> <http://surveys.nees.com.br/ontologies/gado_core.owl#Win_States> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Cooperation> a owl:Class ;
    rdfs:comment "Players must work together to achieve a shared goal"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification> a owl:Class ;
    rdfs:comment "Use of game design elements in non-game contexts."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification_Context> a owl:Class ;
    rdfs:comment "Context of gamification refers to the core service or an activity being gamified"@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Levels> a owl:Class ;
    rdfs:comment "Defined steps in player progression"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Competition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Status> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Resource_Acquisition> a owl:Class ;
    rdfs:comment "Obtaining useful or collectible items"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Story> a owl:Class ;
    rdfs:comment "A narrative structure used to give meaning, context, and progression to gamified experiences."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Theme> a owl:Class ;
    rdfs:comment "A visual or conceptual setting that gives coherence to the gamified experience."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Self-Determination_Theory> a owl:Class ;
    rdfs:comment "An approach to human motivation and personality that uses traditional empirical methods while employing an organismic metatheory that highlights the importance of humans' evolved inner resources for personality development and behavioral self-regulation"@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation_And_Need_Theory> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yee_Immersion_Component> a owl:Class ;
    rdfs:comment "A motivational component from Yee's taxonomy centered on story immersion and world exploration."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Yees_Motivational_Components> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Yees_Motivational_Components> a owl:Class ;
    rdfs:comment "Motivational components based on an extensive survey of MMORPG players."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Model> .

<http://surveys.nees.com.br/ontologies/gato.owl#GamifiedITS> a owl:Class .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGInstrutionalPlan> a owl:Class ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#THINGPedagogicalModel> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#KnowledgeUnit> a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasConceptualKnowledge> ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#hasBehaviouralKnowledge> ],
        <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#MatchColumnOption> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Badges> a owl:Class ;
    rdfs:comment "A visual token of a achievement. Usually designed to look like the real-world analogs, such as Boy Scout badges or the Good Housekeeping seal"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges> <http://surveys.nees.com.br/ontologies/gado_core.owl#Feedback> <http://surveys.nees.com.br/ontologies/gado_core.owl#Rewards> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Leaderboards> a owl:Class ;
    rdfs:comment "A ranked list of participants in a game, with the highest scores on top."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Competition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Feedback> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Win_States> a owl:Class ;
    rdfs:comment "The outcomes of a game that constitute “winning”. Typically defined by the rules of the game and the game’s feedback or rewards mechanisms."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Activity_Loop> a owl:Class ;
    rdfs:comment "Loop of activities in a game-like context."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Engagement_Loop> a owl:Class ;
    rdfs:comment "Engagement Loops (micro level; individual user action)."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_full.owl#Activity_Loop> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Metric> a owl:Class ;
    rdfs:comment "A standard of measurent for target behavior."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Player_Action> a owl:Class ;
    rdfs:comment "The actions of a player in a gamified context."@en .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Context> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Activity> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Content> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#WritingEvaluation> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Dynamic> a owl:Class ;
    rdfs:comment "The conceptual structures underlying a game, such as the narrative and rules (constraints) that shape the game. These are the most abstract game elements. Players feel their effects but do not engage with them directly."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Model> a owl:Class ;
    rdfs:comment "A conceptual model describing player characteristics, preferences, or behavior patterns."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior> a owl:Class ;
    rdfs:comment "The expected behavior in the Fogg's Behavior Model."@en ;
    owl:equivalentClass <http://surveys.nees.com.br/ontologies/gado_full.owl#Player_Action> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#PedagogicalUnit> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Hint> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ThingResource> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Competition> a owl:Class ;
    rdfs:comment "One player or group wins, and the other loses"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Feedback> a owl:Class ;
    rdfs:comment "Information about how the player is doing."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_full.owl#Target_Behavior_Category> a owl:Class ;
    rdfs:comment "A category of Target Behavior based on empirical data in the literature."@en .

<http://surveys.nees.com.br/ontologies/gado_full.owl#coversComponent> a owl:ObjectProperty ;
    rdfs:comment "Indicates that a player type is covered or characterized by a motivational component."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#ResourceUnit> a owl:Class ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Sequencing> .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Tactic> a owl:Class ;
    rdfs:comment "Represents all the actions the educational system can do in order to teach."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#PedagogicalModel> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Motivation> a owl:Class ;
    rdfs:comment "Motivation is literally the desire to do things."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Player> a owl:Class ;
    rdfs:comment "An individual or entity that engages with gamified content, performing actions and receiving feedback."@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Rewards> a owl:Class ;
    rdfs:comment "Benefits for some action or achievement"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:unionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> ) ] ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#Strategy> a owl:Class ;
    rdfs:comment "Represents the teaching  mechanism in the instrutional plan."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/its/its.pedagogical.owl#PedagogicalModel> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Option> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges> a owl:Class ;
    rdfs:comment "Puzzles or other tasks that require effort to solve"@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> [ a owl:Restriction ;
                        owl:allValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> ;
                        owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> ] ) ] .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element> a owl:Class ;
    rdfs:comment "A design pattern that can be incorporated into a game. Game elements are the pieces that a game designer assembles in creating an engaging experience"@en .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> a owl:Class ;
    rdfs:comment "A consistent, ongoing storyline"@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Dynamic> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> a owl:Class ;
    rdfs:comment "Curiosity, competitiveness, frustration, happiness, and so on"@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Dynamic> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> a owl:Class ;
    rdfs:comment "Limitations or forced trade-offs"@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Dynamic> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> a owl:Class ;
    rdfs:comment "Social interactions generating feelings of camaraderie, status, altruism, and so on"@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Dynamic> .

<http://surveys.nees.com.br/ontologies/gado_full.owl#isMotivatedWith> a owl:ObjectProperty ;
    rdfs:comment "Associates a motivational component with the game elements that support it."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_full.owl#Yees_Motivational_Components> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Player_Type> a owl:Class ;
    rdfs:comment "A classification of players based on behavior, motivation, or play style."@en .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#ProblemBasedEvaluation> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#EvaluationResource> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#ConceptualKnowledge> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Curriculum.owl#THINGCurriculum> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> a owl:Class ;
    rdfs:comment "The player’s growth and development"@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Dynamic> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#Domain> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.owl#DomainModel> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> a owl:Class ;
    rdfs:comment "The processes that drive forward the action in a game, such as feedback or turns. Game mechanics are the actions that implement higher-level game dynamics and manifest themselves in lower-level game components."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <http://surveys.nees.com.br/ontologies/gado_core.owl#tiesComponent> ;
            owl:someValuesFrom <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> ],
        <http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#Non-Game_Context> a owl:Class ;
    rdfs:comment "A real-world or service context that is not inherently a game but can be enriched with gamification."@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#Gamification_Context> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> a owl:Class .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Problem> a owl:Class ;
    rdfs:subClassOf <http://meututor.com.br/Ontologies/MeuTutor.Domain.Resource.owl#Resource> .

<http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> a owl:Class ;
    rdfs:comment "A particular structure in a game, implementing the game’s mechanics and dynamics. Points and badges are examples of game components"@en ;
    rdfs:subClassOf <http://surveys.nees.com.br/ontologies/gado_core.owl#Game_Design_Element> .

<http://meututor.com.br/Ontologies/MeuTutor.Domain.CP.owl#Curriculum> a owl:Class .

<http://surveys.nees.com.br/ontologies/gado_core.owl#isTiedTo> a owl:ObjectProperty ;
    rdfs:comment "Relates a game design element to the component or mechanic it supports."@en ;
    rdfs:domain <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Component> ;
    rdfs:range <http://surveys.nees.com.br/ontologies/gado_core.owl#GDE_Mechanic> ;
    owl:inverseOf <http://surveys.nees.com.br/ontologies/gado_core.owl#tiesComponent> .

[] a owl:AllDisjointClasses ;
    owl:members ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Achievements> <http://surveys.nees.com.br/ontologies/gado_core.owl#Avatars> <http://surveys.nees.com.br/ontologies/gado_core.owl#Badges> <http://surveys.nees.com.br/ontologies/gado_core.owl#Boss_Fights> <http://surveys.nees.com.br/ontologies/gado_core.owl#Collections> <http://surveys.nees.com.br/ontologies/gado_core.owl#Combat> <http://surveys.nees.com.br/ontologies/gado_core.owl#Content_Unlocking> <http://surveys.nees.com.br/ontologies/gado_core.owl#Gifting> <http://surveys.nees.com.br/ontologies/gado_core.owl#Leaderboards> <http://surveys.nees.com.br/ontologies/gado_core.owl#Levels> <http://surveys.nees.com.br/ontologies/gado_core.owl#Points> <http://surveys.nees.com.br/ontologies/gado_core.owl#Quests> <http://surveys.nees.com.br/ontologies/gado_core.owl#Social_Graph> <http://surveys.nees.com.br/ontologies/gado_core.owl#Teams> <http://surveys.nees.com.br/ontologies/gado_core.owl#Time_Constraints> <http://surveys.nees.com.br/ontologies/gado_core.owl#Virtual_Goods> ) .

[] a owl:AllDisjointClasses ;
    owl:members ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Challenges> <http://surveys.nees.com.br/ontologies/gado_core.owl#Chances> <http://surveys.nees.com.br/ontologies/gado_core.owl#Competition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Cooperation> <http://surveys.nees.com.br/ontologies/gado_core.owl#Feedback> <http://surveys.nees.com.br/ontologies/gado_core.owl#Resource_Acquisition> <http://surveys.nees.com.br/ontologies/gado_core.owl#Rewards> <http://surveys.nees.com.br/ontologies/gado_core.owl#Status> <http://surveys.nees.com.br/ontologies/gado_core.owl#Theme> <http://surveys.nees.com.br/ontologies/gado_core.owl#Transactions> <http://surveys.nees.com.br/ontologies/gado_core.owl#Turns> <http://surveys.nees.com.br/ontologies/gado_core.owl#Win_States> ) .

[] a owl:AllDisjointClasses ;
    owl:members ( <http://surveys.nees.com.br/ontologies/gado_core.owl#Constraints> <http://surveys.nees.com.br/ontologies/gado_core.owl#Emotions> <http://surveys.nees.com.br/ontologies/gado_core.owl#Narrative> <http://surveys.nees.com.br/ontologies/gado_core.owl#Progression> <http://surveys.nees.com.br/ontologies/gado_core.owl#Relationships> ) .

