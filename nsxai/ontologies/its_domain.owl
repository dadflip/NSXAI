<?xml version="1.0"?>
<Ontology xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://surveys.nees.com.br/ontologies/its_domain.owl"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     ontologyIRI="http://surveys.nees.com.br/ontologies/its_domain.owl">
    <Prefix name="" IRI="http://surveys.nees.com.br/ontologies/its_domain.owl#"/>
    <Prefix name="its" IRI="http://surveys.nees.com.br/ontologies/its_domain.owl#"/>
    <Prefix name="owl" IRI="http://www.w3.org/2002/07/owl#"/>
    <Prefix name="rdf" IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
    <Prefix name="xml" IRI="http://www.w3.org/XML/1998/namespace"/>
    <Prefix name="xsd" IRI="http://www.w3.org/2001/XMLSchema#"/>
    <Prefix name="rdfs" IRI="http://www.w3.org/2000/01/rdf-schema#"/>
    <Prefix name="mt"   IRI="http://meututor.com.br/Ontologies/meututor_domain.owl#"/>
    <Prefix name="mtcp" IRI="http://meututor.com.br/Ontologies/meututor_domain_cp.owl#"/>
    <Prefix name="mtcu" IRI="http://meututor.com.br/Ontologies/meututor_domain_curriculum.owl#"/>
    <Prefix name="mtr"  IRI="http://meututor.com.br/Ontologies/meututor_domain_resource.owl#"/>
    <Import>http://meututor.com.br/Ontologies/meututor_domain.owl</Import>
    <Import>http://meututor.com.br/Ontologies/meututor_domain_cp.owl</Import>
    <Import>http://meututor.com.br/Ontologies/meututor_domain_curriculum.owl</Import>
    <Import>http://meututor.com.br/Ontologies/meututor_domain_resource.owl</Import>
    <Import>http://rdfs.org/sioc/ns</Import>
        <Annotation><AnnotationProperty abbreviatedIRI="rdfs:label"/><Literal xml:lang="en">ITS Domain Ontology</Literal></Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <Literal xml:lang="en">
      Consolidated ITS domain ontology covering courses, knowledge domains, curriculum,
      pedagogical units, and learning resources. Derived from MeuTutor domain ontologies.
      The pedagogical layer (strategies, tactics, instructional plans) is defined separately
      in its.pedagogical.owl, which imports this ontology.
    </Literal>
    </Annotation>
        <Annotation><AnnotationProperty abbreviatedIRI="owl:versionInfo"/><Literal>1.1</Literal></Annotation>

        <Declaration><Class IRI="http://rdfs.org/sioc/ns#UserAccount"/></Declaration>
        <Declaration><Class IRI="#Course"/></Declaration>

        <Declaration><ObjectProperty IRI="#teachesDomain"/></Declaration>

        <Declaration><DataProperty IRI="#courseName"/></Declaration>
        <Declaration><DataProperty IRI="#teacher"/></Declaration>

        <ObjectPropertyDomain><ObjectProperty IRI="#teachesDomain"/><Class IRI="#Course"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#teachesDomain"/><Class abbreviatedIRI="mt:Domain"/></ObjectPropertyRange>

        <FunctionalDataProperty><DataProperty IRI="#courseName"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#courseName"/><Class IRI="#Course"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#courseName"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#teacher"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#teacher"/><Class IRI="#Course"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#teacher"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>

    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcp:Context</IRI>
        <Literal xml:lang="en">
      Represents a particular standpoint or interpretation of a knowledge domain.
      Different Contexts yield different representations of the same knowledge object.
    </Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcp:Curriculum</IRI>
        <Literal xml:lang="en">
      A Curriculum node is a &lt;Context, Depth&gt; pair that groups a set of Pedagogical Units
      defined according to teaching/learning objectives.
    </Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcp:Depth</IRI>
        <Literal xml:lang="en">
      Stratifies the epistemological levels of knowledge-object perception within a given Context.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcp:hasContext</IRI><Literal xml:lang="en">Associates an entity with its Context.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcp:importanceLevel</IRI><Literal xml:lang="en">Relative importance of this Curriculum node within the domain.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcp:isChildOfCurriculum</IRI><Literal xml:lang="en">Transitive child relationship between Curriculum nodes.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcp:isComposedByContext</IRI><Literal xml:lang="en">A Curriculum is composed by exactly one Context.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcp:isComposedByDepth</IRI><Literal xml:lang="en">A Curriculum is composed by exactly one Depth level.</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcp:isComposedByLaterality</IRI>
        <Literal xml:lang="en">
      Relates a Curriculum to sibling Curricula that represent prerequisite knowledge
      from a particular Context/Depth perspective.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcp:isParentOfCurriculum</IRI><Literal xml:lang="en">Transitive parent relationship between Curriculum nodes.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcp:issue</IRI><Literal xml:lang="en">Human-readable label / identifier for a Context, Curriculum or Depth node.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcp:type</IRI><Literal xml:lang="en">Classification type of a Context (e.g. formal, informal, professional).</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcu:BehaviouralKnowledge</IRI>
        <Literal xml:lang="en">
      Encodes the domain-specific inference rules or procedures a student should be able to perform.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:Bug</IRI><Literal xml:lang="en">A systematic procedural error in the student's behavioural knowledge.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:Bug_Misconception</IRI><Literal xml:lang="en">A catalogue entry that is simultaneously a Bug and a Misconception.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:CKCurriculumInformation</IRI><Literal xml:lang="en">Metadata linking a ConceptualKnowledge node to its Curriculum position (cluster, precedence).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:Catalogue</IRI><Literal xml:lang="en">Abstract catalogue of known student difficulties (bugs, errors, misconceptions).</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcu:ConceptualKnowledge</IRI>
        <Literal xml:lang="en">
      Contains the definitions of concepts underlying the Behavioural Knowledge,
      i.e. the concepts involved in an inference mechanism.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:Error</IRI><Literal xml:lang="en">A specific incorrect response or calculation error.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:Error_Bug</IRI><Literal xml:lang="en">A catalogue entry that is simultaneously a Bug and an Error.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:Error_Misconception</IRI><Literal xml:lang="en">A catalogue entry that is simultaneously an Error and a Misconception.</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcu:GenericOperator</IRI>
        <Literal xml:lang="en">
      Defines how the system knowledge (Rs*k) and the bug/misconception catalogues
      interact to create a diagnosis space.
    </Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcu:KnowledgeUnit</IRI>
        <Literal xml:lang="en">
      Groups support knowledge for problem-solving: concepts, results, examples, counter-examples,
      hints, and analogous problems (from the same class).
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:Misconception</IRI><Literal xml:lang="en">A faulty conceptual belief held by the student.</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcu:PedagogicalUnit</IRI>
        <Literal xml:lang="en">
      A Pedagogical Unit (PU) corresponds to a set of problems and resources ordered
      according to pedagogical criteria.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:ResourceWeight</IRI><Literal xml:lang="en">Associates a resource with its relative weight within a pedagogical unit.</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcu:UniversalGenericOperator</IRI>
        <Literal xml:lang="en">
      Represents any Behavioural Knowledge associated with all bugs in the bug catalogue.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:ckType</IRI><Literal xml:lang="en">Classifies the type of conceptual knowledge (e.g. declarative, procedural).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:cluster</IRI><Literal xml:lang="en">Cluster identifier grouping related ConceptualKnowledge nodes.</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcu:difficulty</IRI>
        <Literal xml:lang="en">
      Represents how difficult the learning resource is for the typical target audience.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:domain</IRI><Literal xml:lang="en">String identifier of the knowledge domain (used when a full IRI reference is not available).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasBehaviouralKnowledge</IRI><Literal xml:lang="en">Associates a knowledge entity with its Behavioural Knowledge definition.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasCatalogue</IRI><Literal xml:lang="en">Associates a knowledge entity with its bug/error/misconception Catalogue.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasConceptualKnowledge</IRI><Literal xml:lang="en">Associates a knowledge entity with its Conceptual Knowledge definition.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasConsistency</IRI><Literal xml:lang="en">Consistency indicator for a curriculum entity.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasDiscrepancy</IRI><Literal xml:lang="en">Records a discrepancy detected by a Generic Operator.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasDomain</IRI><Literal xml:lang="en">Links a ConceptualKnowledge node to its knowledge Domain.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasExplanation</IRI><Literal xml:lang="en">Links a knowledge entity to an explanatory Learning Object.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasKnowledgeUnit</IRI><Literal xml:lang="en">A Pedagogical Unit is associated with exactly one Knowledge Unit.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasLO</IRI><Literal xml:lang="en">Super-property grouping all Learning Object associations.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasPG</IRI><Literal xml:lang="en">BKT parameter: probability of a correct guess (P(G)).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasPL0</IRI><Literal xml:lang="en">BKT parameter: initial probability of knowledge (P(L0)).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasPS</IRI><Literal xml:lang="en">BKT parameter: probability of a slip / incorrect answer despite knowledge (P(S)).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasPT</IRI><Literal xml:lang="en">BKT parameter: probability of learning / transition (P(T)).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasPedagogicalUnit</IRI><Literal xml:lang="en">A Curriculum contains one or more Pedagogical Units.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasSuperConceptualKnowledge</IRI><Literal xml:lang="en">Points to the parent ConceptualKnowledge in a generalisation hierarchy.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:hasTags</IRI><Literal xml:lang="en">Free-text tags associated with a ConceptualKnowledge node.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:has_Curriculum</IRI><Literal xml:lang="en">Functional shortcut linking any entity to its single Curriculum.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:has_MissConception</IRI><Literal xml:lang="en">Links a Diagnosis to the ConceptualKnowledge node that represents the misconception.</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtcu:isComposedByLaterality</IRI>
        <Literal xml:lang="en">
      Relates a Knowledge Unit to prerequisite Curricula (lateral knowledge),
      i.e. supportive knowledge from a given Context/Depth perspective.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:isComposedByProblem</IRI><Literal xml:lang="en">Relates a catalogue entry to the problem that triggers it.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:issue</IRI><Literal xml:lang="en">Human-readable label / identifier for a ConceptualKnowledge or PedagogicalUnit node.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:precedence</IRI><Literal xml:lang="en">Ordering precedence of a knowledge node within its curriculum.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:rate</IRI><Literal xml:lang="en">Frequency/probability rate of the bug, error, or misconception.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtcu:weight</IRI><Literal xml:lang="en">Relative weight of a resource within a pedagogical unit.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Activity</IRI><Literal xml:lang="en">A student activity resource with defined start/end dates and weight.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Comment</IRI><Literal xml:lang="en">A peer or instructor comment attached to a Problem.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:CompositeResource</IRI><Literal xml:lang="en">A resource composed of multiple atomic (non-composite) resources.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Concept</IRI><Literal xml:lang="en">A definitional concept resource presented to the student.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Content</IRI><Literal xml:lang="en">A content resource (e.g. lecture notes, video, reading material).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Diagnosis</IRI><Literal xml:lang="en">A diagnostic result triggered by a student selecting a particular Option.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:DiscursiveProblem</IRI><Literal xml:lang="en">A free-text / discursive problem requiring an open-ended written answer.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:EvaluationResource</IRI><Literal xml:lang="en">Abstract superclass for all evaluation types.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Exercise</IRI><Literal xml:lang="en">A worked example or exercise resource.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Form</IRI><Literal xml:lang="en">A form-based evaluation containing survey Questions.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Hint</IRI><Literal xml:lang="en">A scaffolded hint provided to a student during problem-solving; hints form a tree.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:MatchColumnAnswer</IRI><Literal xml:lang="en">Identifies the correct matching answer(s) in a MatchColumnProblem.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:MethodStep</IRI><Literal xml:lang="en">An individual step within a ResolutionMethod.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Option</IRI><Literal xml:lang="en">Abstract superclass for all answer options.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:OptionAnswer</IRI><Literal xml:lang="en">The correct answer value ("true" or "false") for a TrueOrFalseOption.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Problem</IRI><Literal xml:lang="en">Abstract superclass for all problem types.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:ProblemBasedEvaluation</IRI><Literal xml:lang="en">An evaluation composed of a set of Problems.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Question</IRI><Literal xml:lang="en">A survey or form question linked to a Curriculum.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Resolution</IRI><Literal xml:lang="en">The worked solution associated with a Problem.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:ResolutionMethod</IRI><Literal xml:lang="en">A named resolution strategy applicable to a problem class.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:ResourceList</IRI><Literal xml:lang="en">Enumerates the atomic resources that compose a CompositeResource.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:Statement</IRI><Literal xml:lang="en">The problem or activity statement presented to the student.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:URIResource</IRI><Literal xml:lang="en">URI pointing to the actual content of a Resource.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:URIType</IRI><Literal xml:lang="en">MIME type or format descriptor of the resource URI.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:WritingEvaluation</IRI><Literal xml:lang="en">A free-text writing evaluation.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:context</IRI><Literal xml:lang="en">Contextual information or scenario description for a Problem.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:corrected</IRI><Literal xml:lang="en">Indicates whether the evaluation has been corrected / graded.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:developmentStatus</IRI><Literal xml:lang="en">Development status of the problem (e.g. draft, reviewed, published).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:difficulty</IRI><Literal xml:lang="en">IRT difficulty parameter for a Problem.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:duration</IRI><Literal xml:lang="en">Estimated duration of the content resource in minutes.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:enabled</IRI><Literal xml:lang="en">Indicates whether a resource is currently available to students.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:error</IRI><Literal xml:lang="en">Description of the diagnosed error.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:hasCalculations</IRI><Literal xml:lang="en">Indicates whether the problem involves numerical calculations.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:hasOption</IRI><Literal xml:lang="en">Generic option association; specialised by problem-type sub-properties.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:has_Answers</IRI><Literal xml:lang="en">Accepted answer(s) for a fill-in-the-blanks option (pipe-separated if multiple).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:has_Diagnosis</IRI><Literal xml:lang="en">Links an Option to the Diagnosis it triggers when chosen.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:has_Epoch</IRI><Literal xml:lang="en">Training epoch number associated with a problem-based evaluation (used in adaptive systems).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:has_Knowledge</IRI><Literal xml:lang="en">Knowledge component addressed by a form question.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:has_token</IRI><Literal xml:lang="en">Access token or identifier for a specific problem instance.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:issue</IRI><Literal xml:lang="en">Known issue or errata associated with a Content resource.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:item</IRI><Literal xml:lang="en">The text content of an option presented to the student.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:level</IRI><Literal xml:lang="en">Proficiency level required for an activity or problem.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:matched_To</IRI><Literal xml:lang="en">Links a left-column option to its corresponding right-column match.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:multipleChoiceAnswer</IRI><Literal xml:lang="en">Identifies the correct option(s) in a MultipleChoiceProblem.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:order</IRI><Literal xml:lang="en">Display order of a hint or option within its problem.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:size</IRI><Literal xml:lang="en">Number of problems included in an evaluation.</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtr:subjects</IRI>
        <Literal xml:lang="en">
      Identifies the subject(s) covered by a simple evaluation
      (e.g. a specific domain, a specific curriculum, or all domains).
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:superKC</IRI><Literal xml:lang="en">Identifier of the parent knowledge component in the resource hierarchy.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:term</IRI><Literal xml:lang="en">The canonical term label for a Concept resource.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mtr:tokenized_statement</IRI><Literal xml:lang="en">Tokenised (NLP-processed) version of the problem statement.</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mtr:type_Test</IRI>
        <Literal xml:lang="en">
      Identifies whether an evaluation is simple (linked to a specific Domain or Curriculum)
      or comprehensive (covering all domains).
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:Competence</IRI><Literal xml:lang="en">A competence groups several Domains that a student is expected to master.</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>mt:Domain</IRI>
        <Literal xml:lang="en">
      A knowledge Domain is the subject-matter area taught by an ITS.
      It is structured by at least one Context, Depth level, and Curriculum.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:DomainModel</IRI><Literal xml:lang="en">Answers the question "What to teach?" in an educational system.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:associatedDomain</IRI><Literal xml:lang="en">Associates any resource with its knowledge domain.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:desiredPoints</IRI><Literal xml:lang="en">Target score or point threshold for a student performance goal.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:domain</IRI><Literal xml:lang="en">String label for the Domain (used alongside the IRI).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:hasDomains</IRI><Literal xml:lang="en">Links a Competence to the Domains it covers.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:hasEloRating</IRI><Literal xml:lang="en">Elo rating associated with a domain entity (used for student modelling).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:hasLevel</IRI><Literal xml:lang="en">Proficiency level associated with a domain entity.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:hasSubDomain</IRI><Literal xml:lang="en">Links a domain to one of its sub-domains.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:isComposedByContext</IRI><Literal xml:lang="en">Relates a Domain to the Contexts from which it can be viewed.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:isComposedByCurriculum</IRI><Literal xml:lang="en">Relates a Domain to its constituent Curriculum units.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:isComposedByDepth</IRI><Literal xml:lang="en">Relates a Domain to the Depth levels used to stratify its knowledge.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>mt:type</IRI><Literal xml:lang="en">Classification type of the Domain (e.g. academic, professional, vocational).</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>http://rdfs.org/sioc/ns#UserAccount</IRI><Literal xml:lang="en">A user account (student or instructor) in the ITS platform (from SIOC vocabulary).</Literal></AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Course</IRI>
        <Literal xml:lang="en">
      An ITS Course bundles a set of knowledge Domains and is delivered to enrolled students.
    </Literal>
    </AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#courseName</IRI><Literal xml:lang="en">Official name of the Course.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#teacher</IRI><Literal xml:lang="en">Name of the instructor responsible for the Course.</Literal></AnnotationAssertion>
        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#teachesDomain</IRI><Literal xml:lang="en">Specifies the knowledge Domain taught by a Course.</Literal></AnnotationAssertion>

</Ontology>
