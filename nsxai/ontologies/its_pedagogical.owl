<?xml version="1.0"?>
<Ontology xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://surveys.nees.com.br/ontologies/its/its_pedagogical.owl"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     ontologyIRI="http://surveys.nees.com.br/ontologies/its/its_pedagogical.owl">
    <Prefix name="" IRI="http://surveys.nees.com.br/ontologies/its/its_pedagogical.owl#"/>
    <Prefix name="itsp" IRI="http://surveys.nees.com.br/ontologies/its/its_pedagogical.owl#"/>
    <Prefix name="owl" IRI="http://www.w3.org/2002/07/owl#"/>
    <Prefix name="rdf" IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
    <Prefix name="xml" IRI="http://www.w3.org/XML/1998/namespace"/>
    <Prefix name="xsd" IRI="http://www.w3.org/2001/XMLSchema#"/>
    <Prefix name="rdfs" IRI="http://www.w3.org/2000/01/rdf-schema#"/>
    <Prefix name="mt"   IRI="http://meututor.com.br/Ontologies/meututor_domain.owl#"/>
    <Prefix name="mtcp" IRI="http://meututor.com.br/Ontologies/meututor_domain_cp.owl#"/>
    <Prefix name="mtcu" IRI="http://meututor.com.br/Ontologies/meututor_domain_curriculum.owl#"/>
    <Prefix name="mtr"  IRI="http://meututor.com.br/Ontologies/meututor_domain_resource.owl#"/>
    <Prefix name="its"  IRI="http://surveys.nees.com.br/ontologies/its_domain.owl#"/>
    <Import>http://surveys.nees.com.br/ontologies/its_domain.owl</Import>
        <Annotation><AnnotationProperty abbreviatedIRI="rdfs:label"/><Literal xml:lang="en">ITS Pedagogical Ontology</Literal></Annotation>
        <Annotation><AnnotationProperty abbreviatedIRI="rdfs:comment"/><Literal xml:lang="en">Defines pedagogical models for Intelligent Tutoring Systems: instructional plans, sequencing strategies, tactics, and curriculum units.</Literal></Annotation>

        <Declaration><Class abbreviatedIRI="mtcp:Curriculum"/></Declaration>
        <Declaration><Class IRI="#CurriculumUnit"/></Declaration>
        <Declaration><Class IRI="#InstrutionalPlan"/></Declaration>
        <Declaration><Class IRI="#PedagogicalModel"/></Declaration>
        <Declaration><Class IRI="#ProblemNext"/></Declaration>
        <Declaration><Class IRI="#ProblemUnit"/></Declaration>
        <Declaration><Class IRI="#ResourceUnit"/></Declaration>
        <Declaration><Class IRI="#Sequencing"/></Declaration>
        <Declaration><Class IRI="#Strategy"/></Declaration>
        <Declaration><Class IRI="#THINGInstrutionalPlan"/></Declaration>
        <Declaration><Class IRI="#THINGPedagogicalModel"/></Declaration>
        <Declaration><Class IRI="#Tactic"/></Declaration>

        <Declaration><ObjectProperty IRI="#has_Curriculum"/></Declaration>
        <Declaration><ObjectProperty IRI="#has_PedagogicalUnit"/></Declaration>
        <Declaration><ObjectProperty IRI="#has_Problem"/></Declaration>
        <Declaration><ObjectProperty IRI="#has_ProblemNext"/></Declaration>
        <Declaration><ObjectProperty IRI="#has_Resource"/></Declaration>
        <Declaration><ObjectProperty IRI="#has_Sequencing"/></Declaration>
        <Declaration><ObjectProperty IRI="#has_domain"/></Declaration>
        <Declaration><ObjectProperty IRI="#isChildOf_Strategy"/></Declaration>
        <Declaration><ObjectProperty IRI="#isChildOf_Tactic"/></Declaration>
        <Declaration><ObjectProperty IRI="#isParentOf_Strategy"/></Declaration>
        <Declaration><ObjectProperty IRI="#isParentOf_Tactic"/></Declaration>
        <Declaration><ObjectProperty IRI="#next_Curriculum"/></Declaration>
        <Declaration><ObjectProperty IRI="#next_Unit"/></Declaration>
        <Declaration><ObjectProperty IRI="#previous_Unit"/></Declaration>
        <Declaration><ObjectProperty IRI="#strategicTutoring"/></Declaration>

        <Declaration><DataProperty IRI="#Level"/></Declaration>
        <Declaration><DataProperty IRI="#abilityScoreMean"/></Declaration>
        <Declaration><DataProperty IRI="#abilityScoreStandardDeviation"/></Declaration>
        <Declaration><DataProperty IRI="#isExplained"/></Declaration>
        <Declaration><DataProperty IRI="#score_Max"/></Declaration>
        <Declaration><DataProperty IRI="#score_Min"/></Declaration>
        <Declaration><DataProperty IRI="#statement"/></Declaration>
        <Declaration><DataProperty IRI="#strategy"/></Declaration>
        <Declaration><DataProperty IRI="#tactic"/></Declaration>
        <Declaration><DataProperty IRI="#time"/></Declaration>
        <Declaration><DataProperty IRI="#type"/></Declaration>
        <Declaration><DataProperty IRI="#typeAssessment"/></Declaration>
        <Declaration><DataProperty IRI="#typeStrategy"/></Declaration>
        <Declaration><DataProperty IRI="#typeStrategyTutoring"/></Declaration>
        <Declaration><DataProperty IRI="#typeTactic"/></Declaration>
        <Declaration><DataProperty IRI="#value"/></Declaration>

    <SubClassOf>
        <Class IRI="#CurriculumUnit"/>
        <ObjectMaxCardinality cardinality="1">
            <ObjectProperty IRI="#next_Curriculum"/>
        </ObjectMaxCardinality>
    </SubClassOf>
        <SubClassOf><Class IRI="#CurriculumUnit"/><Class IRI="#THINGInstrutionalPlan"/></SubClassOf>
        <SubClassOf><Class IRI="#InstrutionalPlan"/><Class IRI="#PedagogicalModel"/></SubClassOf>
        <SubClassOf><Class IRI="#ProblemNext"/><Class IRI="#THINGInstrutionalPlan"/></SubClassOf>
        <SubClassOf><Class IRI="#ProblemUnit"/><Class IRI="#Sequencing"/></SubClassOf>
        <SubClassOf><Class IRI="#ResourceUnit"/><Class IRI="#Sequencing"/></SubClassOf>
        <SubClassOf><Class IRI="#Sequencing"/><Class IRI="#THINGInstrutionalPlan"/></SubClassOf>
        <SubClassOf><Class IRI="#Strategy"/><Class IRI="#PedagogicalModel"/></SubClassOf>
        <SubClassOf><Class IRI="#THINGInstrutionalPlan"/><Class IRI="#THINGPedagogicalModel"/></SubClassOf>
        <SubClassOf><Class IRI="#Tactic"/><Class IRI="#PedagogicalModel"/></SubClassOf>

        <FunctionalObjectProperty><ObjectProperty IRI="#has_Curriculum"/></FunctionalObjectProperty>
        <ObjectPropertyDomain><ObjectProperty IRI="#has_Curriculum"/><Class IRI="#CurriculumUnit"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#has_Curriculum"/><Class abbreviatedIRI="mtcp:Curriculum"/></ObjectPropertyRange>
        <FunctionalObjectProperty><ObjectProperty IRI="#has_PedagogicalUnit"/></FunctionalObjectProperty>
        <ObjectPropertyDomain><ObjectProperty IRI="#has_PedagogicalUnit"/><Class IRI="#InstrutionalPlan"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#has_PedagogicalUnit"/><Class abbreviatedIRI="mtcu:PedagogicalUnit"/></ObjectPropertyRange>
        <FunctionalObjectProperty><ObjectProperty IRI="#has_Problem"/></FunctionalObjectProperty>
        <ObjectPropertyDomain><ObjectProperty IRI="#has_Problem"/><Class IRI="#ProblemUnit"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#has_Problem"/><Class abbreviatedIRI="mtr:Problem"/></ObjectPropertyRange>
        <ObjectPropertyDomain><ObjectProperty IRI="#has_ProblemNext"/><Class IRI="#ProblemUnit"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#has_ProblemNext"/><Class IRI="#ProblemNext"/></ObjectPropertyRange>
        <FunctionalObjectProperty><ObjectProperty IRI="#has_Resource"/></FunctionalObjectProperty>
        <ObjectPropertyDomain><ObjectProperty IRI="#has_Resource"/><Class IRI="#ResourceUnit"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#has_Resource"/><Class abbreviatedIRI="mtr:Resource"/></ObjectPropertyRange>
        <FunctionalObjectProperty><ObjectProperty IRI="#has_Sequencing"/></FunctionalObjectProperty>
        <ObjectPropertyDomain><ObjectProperty IRI="#has_Sequencing"/><Class IRI="#InstrutionalPlan"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#has_Sequencing"/><Class IRI="#Sequencing"/></ObjectPropertyRange>
        <FunctionalObjectProperty><ObjectProperty IRI="#has_domain"/></FunctionalObjectProperty>
        <TransitiveObjectProperty><ObjectProperty IRI="#isChildOf_Strategy"/></TransitiveObjectProperty>
        <InverseObjectProperties><ObjectProperty IRI="#isChildOf_Strategy"/><ObjectProperty IRI="#isParentOf_Strategy"/></InverseObjectProperties>
        <ObjectPropertyDomain><ObjectProperty IRI="#isChildOf_Strategy"/><Class IRI="#Strategy"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#isChildOf_Strategy"/><Class IRI="#Strategy"/></ObjectPropertyRange>
        <InverseObjectProperties><ObjectProperty IRI="#isChildOf_Tactic"/><ObjectProperty IRI="#isParentOf_Tactic"/></InverseObjectProperties>
        <ObjectPropertyDomain><ObjectProperty IRI="#isChildOf_Tactic"/><Class IRI="#Tactic"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#isChildOf_Tactic"/><Class IRI="#Tactic"/></ObjectPropertyRange>
        <TransitiveObjectProperty><ObjectProperty IRI="#isParentOf_Strategy"/></TransitiveObjectProperty>
        <InverseObjectProperties><ObjectProperty IRI="#isParentOf_Strategy"/><ObjectProperty IRI="#isChildOf_Strategy"/></InverseObjectProperties>
        <ObjectPropertyDomain><ObjectProperty IRI="#isParentOf_Strategy"/><Class IRI="#Strategy"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#isParentOf_Strategy"/><Class IRI="#Strategy"/></ObjectPropertyRange>
        <TransitiveObjectProperty><ObjectProperty IRI="#isParentOf_Tactic"/></TransitiveObjectProperty>
        <InverseObjectProperties><ObjectProperty IRI="#isParentOf_Tactic"/><ObjectProperty IRI="#isChildOf_Tactic"/></InverseObjectProperties>
        <ObjectPropertyDomain><ObjectProperty IRI="#isParentOf_Tactic"/><Class IRI="#Tactic"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#isParentOf_Tactic"/><Class IRI="#Tactic"/></ObjectPropertyRange>
        <FunctionalObjectProperty><ObjectProperty IRI="#next_Curriculum"/></FunctionalObjectProperty>
        <ObjectPropertyDomain><ObjectProperty IRI="#next_Curriculum"/><Class IRI="#CurriculumUnit"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#next_Curriculum"/><Class IRI="#CurriculumUnit"/></ObjectPropertyRange>
        <FunctionalObjectProperty><ObjectProperty IRI="#next_Unit"/></FunctionalObjectProperty>
        <ObjectPropertyDomain><ObjectProperty IRI="#next_Unit"/><Class IRI="#ResourceUnit"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#next_Unit"/><Class IRI="#ResourceUnit"/></ObjectPropertyRange>
        <ObjectPropertyDomain><ObjectProperty IRI="#previous_Unit"/><Class IRI="#ResourceUnit"/></ObjectPropertyDomain>
        <ObjectPropertyRange><ObjectProperty IRI="#previous_Unit"/><Class IRI="#ResourceUnit"/></ObjectPropertyRange>
        <FunctionalObjectProperty><ObjectProperty IRI="#strategicTutoring"/></FunctionalObjectProperty>
        <ObjectPropertyRange><ObjectProperty IRI="#strategicTutoring"/><Class IRI="#Strategy"/></ObjectPropertyRange>

        <FunctionalDataProperty><DataProperty IRI="#Level"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#Level"/><Class IRI="#InstrutionalPlan"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#Level"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#abilityScoreMean"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#abilityScoreMean"/><Class abbreviatedIRI="mt:Domain"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#abilityScoreMean"/><Datatype abbreviatedIRI="xsd:float"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#abilityScoreStandardDeviation"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#abilityScoreStandardDeviation"/><Class abbreviatedIRI="mt:Domain"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#abilityScoreStandardDeviation"/><Datatype abbreviatedIRI="xsd:float"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#isExplained"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#isExplained"/><Class IRI="#ProblemUnit"/></DataPropertyDomain>
        <FunctionalDataProperty><DataProperty IRI="#score_Max"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#score_Max"/><Class IRI="#ProblemNext"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#score_Max"/><Datatype abbreviatedIRI="xsd:float"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#score_Min"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#score_Min"/><Class IRI="#ProblemNext"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#score_Min"/><Datatype abbreviatedIRI="xsd:float"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#statement"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#statement"/><Class IRI="#ResourceUnit"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#statement"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#strategy"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#strategy"/><Class IRI="#Strategy"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#strategy"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#tactic"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#tactic"/><Class IRI="#Tactic"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#tactic"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#time"/></FunctionalDataProperty>
        <DataPropertyRange><DataProperty IRI="#time"/><Datatype abbreviatedIRI="xsd:float"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#type"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#type"/><Class IRI="#ResourceUnit"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#type"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <DataPropertyDomain><DataProperty IRI="#typeAssessment"/><Class IRI="#Tactic"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#typeAssessment"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#typeStrategy"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#typeStrategy"/><Class IRI="#Strategy"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#typeStrategy"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <DataPropertyDomain><DataProperty IRI="#typeStrategyTutoring"/><Class IRI="#Strategy"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#typeStrategyTutoring"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#typeTactic"/></FunctionalDataProperty>
        <DataPropertyDomain><DataProperty IRI="#typeTactic"/><Class IRI="#Tactic"/></DataPropertyDomain>
        <DataPropertyRange><DataProperty IRI="#typeTactic"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
        <FunctionalDataProperty><DataProperty IRI="#value"/></FunctionalDataProperty>
        <DataPropertyRange><DataProperty IRI="#value"/><Datatype abbreviatedIRI="xsd:float"/></DataPropertyRange>

        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#InstrutionalPlan</IRI><Literal xml:lang="en">Instructional Plan Strategy.</Literal></AnnotationAssertion>

        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#PedagogicalModel</IRI><Literal xml:lang="en">Answer the question: How to teach? in a educational system.</Literal></AnnotationAssertion>

        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Sequencing</IRI><Literal xml:lang="en">A Sequencing is a map that represents the intended use of the content through structured units of instruction (curriculum).</Literal></AnnotationAssertion>

        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Strategy</IRI><Literal xml:lang="en">Represents the teaching  mechanism in the instrutional plan.</Literal></AnnotationAssertion>

        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#Tactic</IRI><Literal xml:lang="en">Represents all the actions the educational system can do in order to teach.</Literal></AnnotationAssertion>

        <AnnotationAssertion><AnnotationProperty abbreviatedIRI="rdfs:comment"/><IRI>#strategicTutoring</IRI><Literal xml:lang="en">The strategy is alike a template with configuration to select tactics.</Literal></AnnotationAssertion>

</Ontology>
