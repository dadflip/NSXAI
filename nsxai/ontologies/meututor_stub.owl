<?xml version="1.0"?>
<!--
  meututor_stub.owl
  Stub ontology covering all MeuTutor terms referenced in the ITS ontology suite.
  These declarations resolve the "Unknown" status in owlready2/Protégé by providing
  local definitions for the external meututor.com.br namespace.
-->
